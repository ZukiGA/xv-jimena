---
// Gallery — clean grid, no labels
---

<section id="galeria" class="py-20 px-6 section-photo" style="background-image: url('/images/bg/snow-mountain.jpg')">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-white mb-12">Jimena</h2>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {Array.from({ length: 9 }).map((_, i) => (
        <div class="aspect-square rounded-lg overflow-hidden group">
          <img
            src={`/images/gallery/${i + 1}.jpg`}
            alt=""
            class="w-full h-full object-cover hidden group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            onload="this.classList.remove('hidden'); this.nextElementSibling.classList.add('hidden')"
          />
          <div class="w-full h-full bg-white/5 backdrop-blur-sm border border-white/10 rounded-lg flex items-center justify-center">
            <span class="text-white/15 text-2xl">✧</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
// Photo gallery — growing up photos
---

<section id="galeria" class="py-20 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-white mb-2">Mi Historia</h2>
    <div class="flex items-center justify-center gap-4 mb-4">
      <span class="h-px w-12 bg-white/40"></span>
      <span class="text-white text-sm">✧</span>
      <span class="h-px w-12 bg-white/40"></span>
    </div>
    <p class="text-white/60 italic mb-12">15 años de momentos mágicos</p>

    <!-- Placeholder grid for photos -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {Array.from({ length: 9 }).map((_, i) => (
        <div class="aspect-square rounded-2xl bg-water-shimmer/30 border border-white/40 flex items-center justify-center group hover:scale-[1.02] transition-transform duration-300 overflow-hidden">
          <div class="text-center p-4">
            <p class="text-white/40 text-4xl mb-2">✧</p>
            <p class="text-water-mid/30 font-[Montserrat] text-xs tracking-wider">Foto {i + 1}</p>
          </div>
          <!-- Replace with: <img src={`/photos/jimena-${i + 1}.jpg`} class="w-full h-full object-cover" /> -->
        </div>
      ))}
    </div>
  </div>
</section>

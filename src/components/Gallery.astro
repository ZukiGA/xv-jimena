---
// Photo gallery — growing up photos
---

<section id="galeria" class="py-20 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-white mb-2">Mi Historia</h2>
    <div class="flex items-center justify-center gap-4 mb-4">
      <span class="h-px w-12 bg-white/40"></span>
      <span class="text-white text-sm">✧</span>
      <span class="h-px w-12 bg-white/40"></span>
    </div>
    <p class="text-white/60 italic mb-12">15 años de momentos mágicos</p>

    <!-- Placeholder grid for photos -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {[
        { label: 'Bebé 👶', file: '1' },
        { label: '2-3 años', file: '2' },
        { label: '4-5 años', file: '3' },
        { label: 'Primaria 📚', file: '4' },
        { label: 'Con familia 💕', file: '5' },
        { label: 'Con amigas 👯', file: '6' },
        { label: 'Secundaria 🎓', file: '7' },
        { label: 'Reciente ✨', file: '8' },
        { label: 'La quinceañera 🧚', file: '9' },
      ].map((item) => (
        <div class="aspect-square rounded-2xl overflow-hidden border border-white/40 shadow-md group hover:scale-[1.02] transition-transform duration-300">
          <img
            src={`/images/gallery/${item.file}.jpg`}
            alt={item.label}
            class="w-full h-full object-cover hidden"
            loading="lazy"
            onload="this.classList.remove('hidden'); this.nextElementSibling.classList.add('hidden')"
          />
          <div class="w-full h-full bg-water-shimmer/30 flex items-center justify-center">
            <div class="text-center p-4">
              <p class="text-white/40 text-4xl mb-2">✧</p>
              <p class="text-water-mid/30 font-[Montserrat] text-xs tracking-wider">{item.label}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

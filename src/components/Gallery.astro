---
// Gallery — clean grid
---

<section id="galeria" class="py-20 px-6 bg-[#0f1d2e]">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-white mb-12">Jimena</h2>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {Array.from({ length: 9 }).map((_, i) => (
        <div class="gallery-slot aspect-square rounded-lg overflow-hidden">
          <img
            src={`/images/gallery/${i + 1}.jpg`}
            alt=""
            class="gallery-img w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
          <div class="gallery-placeholder w-full h-full bg-white/5 backdrop-blur-sm border border-white/10 rounded-lg flex items-center justify-center">
            <span class="text-white/15 text-2xl">✧</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-slot {
    position: relative;
  }
  .gallery-img {
    position: relative;
    z-index: 1;
  }
  .gallery-placeholder {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
</style>

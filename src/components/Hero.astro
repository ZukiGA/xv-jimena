---
// Hero — cinematic, Silvermist on top
---

<section class="relative h-[100dvh] text-center overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img src="/images/bg/hero-mountain.jpg" alt="" class="w-full h-full object-cover object-[40%_30%]" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/10 to-black/70"></div>
  </div>

  <!-- Sparkle particles -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="sparkle" style="top: 15%; left: 20%;"></div>
    <div class="sparkle" style="top: 30%; left: 70%; animation-delay: 0.5s;"></div>
    <div class="sparkle" style="top: 60%; left: 40%; animation-delay: 1s;"></div>
    <div class="sparkle" style="top: 45%; left: 85%; animation-delay: 1.5s;"></div>
    <div class="sparkle" style="top: 80%; left: 15%; animation-delay: 0.8s;"></div>
  </div>

  <!-- TOP: Silvermist brand + personalized greeting -->
  <div class="absolute top-8 left-0 right-0 z-10 px-6 animate-fade-in-up">
    <div class="hidden mb-4" id="greeting-wrap">
      <p class="text-white/60 font-[Montserrat] text-xs tracking-[0.3em] uppercase">
        <span id="guest-name" class="text-white/80"></span>, estás invitada(o)
      </p>
    </div>

    <div class="flex items-center justify-center gap-4 mb-3">
      <span class="h-px w-10 bg-[#c0c0c0]/40"></span>
      <span class="text-[#c0c0c0]/50 text-sm">✧</span>
      <span class="h-px w-10 bg-[#c0c0c0]/40"></span>
    </div>
    <p class="text-[#c0c0c0]/80 font-[Montserrat] text-xs tracking-[0.4em] uppercase">
      Silvermist
    </p>
  </div>

  <!-- MIDDLE: Name + XV — positioned at 28% from top -->
  <div class="absolute top-[25%] left-0 right-0 z-10 px-6 animate-fade-in-up" style="animation-delay: 0.3s">
    <h1 class="text-7xl md:text-9xl font-light text-white mb-3 drop-shadow-lg text-reflection" data-text="Jimena">
      Jimena
    </h1>
    <span class="text-2xl md:text-3xl font-[Montserrat] font-light text-white/80 tracking-[0.5em]">XV</span>
  </div>

  <!-- BOTTOM: Date + Location + Scroll -->
  <div class="absolute bottom-5 left-0 right-0 z-10 px-6 animate-fade-in-up" style="animation-delay: 0.6s">
    <p class="text-white/90 font-[Montserrat] text-sm tracking-[0.25em]">
      25 · 07 · 2026
    </p>
    <p class="text-white/40 font-[Montserrat] text-xs mt-2 tracking-wider">
      Santo Tomás Hueyotlipan, Puebla
    </p>

    <div class="mt-8 animate-float">
      <a href="#countdown" class="text-white/40 hover:text-white/60 transition-colors">
        <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

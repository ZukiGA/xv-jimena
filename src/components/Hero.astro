---
// Hero — cinematic, minimal text
---

<section class="relative h-[100dvh] flex flex-col justify-between text-center overflow-hidden py-12">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img src="/images/bg/hero-mountain.jpg" alt="" class="w-full h-full object-cover object-[40%_30%]" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/10 to-black/70"></div>
  </div>

  <!-- Sparkle particles -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="sparkle" style="top: 15%; left: 20%;"></div>
    <div class="sparkle" style="top: 30%; left: 70%; animation-delay: 0.5s;"></div>
    <div class="sparkle" style="top: 60%; left: 40%; animation-delay: 1s;"></div>
    <div class="sparkle" style="top: 45%; left: 85%; animation-delay: 1.5s;"></div>
    <div class="sparkle" style="top: 80%; left: 15%; animation-delay: 0.8s;"></div>
  </div>

  <!-- TOP: Personalized greeting -->
  <div class="relative z-10 px-6">
    <div class="hidden mb-4 animate-fade-in-up" id="greeting-wrap">
      <p class="text-white/70 font-[Montserrat] text-xs tracking-[0.3em] uppercase">
        <span id="guest-name" class="text-white"></span>, estás invitada(o)
      </p>
    </div>

    <p class="text-white/60 font-[Montserrat] text-xs tracking-[0.3em] uppercase animate-fade-in-up">
      Celebremos juntos
    </p>
  </div>

  <!-- MIDDLE: Name + XV -->
  <div class="relative z-10 px-6 animate-fade-in-up" style="animation-delay: 0.3s">
    <div class="flex items-center justify-center gap-4 mb-4">
      <span class="h-px w-16 bg-[#c0c0c0]/50"></span>
      <span class="text-[#c0c0c0]/70 text-xl">✧</span>
      <span class="h-px w-16 bg-[#c0c0c0]/50"></span>
    </div>

    <h1 class="text-6xl md:text-8xl font-light text-white mb-2 drop-shadow-lg text-reflection" data-text="Jimena">
      Jimena
    </h1>

    <span class="text-2xl md:text-3xl font-[Montserrat] font-light text-white/80 tracking-[0.4em]">XV</span>
  </div>

  <!-- Silvermist -->
  <div class="relative z-10 px-6 mb-4 animate-fade-in-up" style="animation-delay: 0.6s">
    <p class="text-[#c0c0c0]/70 font-[Montserrat] text-xs tracking-[0.3em] uppercase">
      Silvermist
    </p>
  </div>

  <!-- BOTTOM: Date + Location + Scroll -->
  <div class="relative z-10 px-6 animate-fade-in-up" style="animation-delay: 0.8s">
    <p class="text-white font-[Montserrat] text-sm tracking-[0.2em]">
      25 · 07 · 2026
    </p>
    <p class="text-white/50 font-[Montserrat] text-xs mt-2 tracking-wider">
      Santo Tomás Hueyotlipan, Puebla
    </p>

    <div class="mt-8 animate-float">
      <a href="#countdown" class="text-white/30 hover:text-white/60 transition-colors">
        <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

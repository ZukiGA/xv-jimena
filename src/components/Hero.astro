---
// Hero section — Silvermist water fairy theme
---

<section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
  <!-- Water/mist background particles -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="sparkle" style="top: 15%; left: 20%;"></div>
    <div class="sparkle" style="top: 30%; left: 70%; animation-delay: 0.5s;"></div>
    <div class="sparkle" style="top: 60%; left: 40%; animation-delay: 1s;"></div>
    <div class="sparkle" style="top: 45%; left: 85%; animation-delay: 1.5s;"></div>
    <div class="sparkle" style="top: 80%; left: 15%; animation-delay: 0.8s;"></div>
    <div class="sparkle" style="top: 20%; left: 55%; animation-delay: 1.2s;"></div>
    <div class="sparkle" style="top: 70%; left: 75%; animation-delay: 0.3s;"></div>
  </div>

  <!-- Decorative wings/water drops -->
  <div class="absolute top-10 left-1/2 -translate-x-1/2 text-water-deep/30 text-8xl select-none animate-float">
    ✧
  </div>

  <div class="relative z-10 px-6 max-w-2xl mx-auto">
    <!-- Pre-title -->
    <p class="text-water-mid font-[Montserrat] text-sm tracking-[0.3em] uppercase mb-4 animate-fade-in-up">
      Con la bendición de Dios y de mis padres
    </p>

    <!-- Divider -->
    <div class="flex items-center justify-center gap-4 mb-6 animate-fade-in-up" style="animation-delay: 0.2s">
      <span class="h-px w-16 bg-silver"></span>
      <span class="text-water-deep text-xl">❀</span>
      <span class="h-px w-16 bg-silver"></span>
    </div>

    <!-- Name -->
    <h1 class="text-6xl md:text-8xl font-light text-water-deep mb-2 animate-fade-in-up" style="animation-delay: 0.4s">
      Jimena
    </h1>

    <!-- XV -->
    <div class="relative inline-block animate-fade-in-up" style="animation-delay: 0.6s">
      <span class="text-3xl md:text-4xl font-light text-water-mid tracking-widest">XV AÑOS</span>
      <div class="animate-shimmer absolute inset-0 rounded-full pointer-events-none"></div>
    </div>

    <!-- Silvermist fairy element -->
    <div class="mt-8 mb-6 animate-fade-in-up" style="animation-delay: 0.8s">
      <p class="text-water-mid/70 italic text-lg">
        ✦ Hada del Agua ✦
      </p>
      <p class="text-accent-lavender/60 font-[Montserrat] text-xs tracking-[0.2em] uppercase mt-1">
        Silvermist
      </p>
    </div>

    <!-- Date -->
    <div class="mt-8 animate-fade-in-up" style="animation-delay: 1s">
      <p class="text-water-deep font-[Montserrat] text-base tracking-[0.15em]">
        25 de Julio de 2026
      </p>
      <p class="text-water-mid/60 font-[Montserrat] text-sm mt-1">
        Salón El Carmen · Santo Tomás Hueyotlipan
      </p>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-16 animate-float">
      <a href="#countdown" class="text-water-deep/50 hover:text-water-mid transition-colors">
        <svg class="w-6 h-6 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

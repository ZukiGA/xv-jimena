---
// WaterTouch — sparkle trail on touch/mouse move
---

<canvas id="water-touch" class="fixed inset-0 z-50 pointer-events-none"></canvas>

<script>
  const canvas = document.getElementById('water-touch') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const dpr = Math.min(window.devicePixelRatio || 1, 2);

  function resize() {
    canvas.width = window.innerWidth * dpr;
    canvas.height = window.innerHeight * dpr;
    canvas.style.width = window.innerWidth + 'px';
    canvas.style.height = window.innerHeight + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  resize();
  window.addEventListener('resize', resize);

  interface Drop {
    x: number; y: number;
    radius: number;
    opacity: number;
    vx: number; vy: number;
    life: number;
    type: 'drop' | 'sparkle' | 'ripple';
    maxRadius?: number;
  }

  const drops: Drop[] = [];
  let lastX = 0, lastY = 0;
  let isActive = false;
  let frameId = 0;
  let lastSpawn = 0;

  function spawnDrops(x: number, y: number) {
    const now = performance.now();
    if (now - lastSpawn < 30) return; // throttle
    lastSpawn = now;

    // Velocity from movement
    const dx = x - lastX;
    const dy = y - lastY;
    const speed = Math.sqrt(dx * dx + dy * dy);

    // Water droplets — scatter from touch point
    const count = Math.min(Math.floor(speed * 0.3) + 1, 4);
    for (let i = 0; i < count; i++) {
      const angle = Math.random() * Math.PI * 2;
      const spread = 1 + Math.random() * 3;
      drops.push({
        x: x + (Math.random() - 0.5) * 10,
        y: y + (Math.random() - 0.5) * 10,
        radius: 2 + Math.random() * 3,
        opacity: 0.4 + Math.random() * 0.3,
        vx: Math.cos(angle) * spread + dx * 0.1,
        vy: Math.sin(angle) * spread + dy * 0.1 + 0.5,
        life: 40 + Math.random() * 20,
        type: 'drop'
      });
    }

    // Sparkle — small bright point
    if (Math.random() > 0.4) {
      drops.push({
        x: x + (Math.random() - 0.5) * 16,
        y: y + (Math.random() - 0.5) * 16,
        radius: 1 + Math.random() * 1.5,
        opacity: 0.6 + Math.random() * 0.4,
        vx: (Math.random() - 0.5) * 1,
        vy: -0.5 - Math.random() * 1,
        life: 30 + Math.random() * 15,
        type: 'sparkle'
      });
    }

    // Mini ripple occasionally
    if (speed > 5 && Math.random() > 0.7) {
      drops.push({
        x, y,
        radius: 0,
        maxRadius: 15 + Math.random() * 15,
        opacity: 0.3,
        vx: 0, vy: 0,
        life: 30,
        type: 'ripple'
      });
    }

    lastX = x;
    lastY = y;
  }

  function animate() {
    ctx.clearRect(0, 0, canvas.width / dpr, canvas.height / dpr);

    for (let i = drops.length - 1; i >= 0; i--) {
      const d = drops[i];
      d.life--;
      if (d.life <= 0) { drops.splice(i, 1); continue; }

      const progress = 1 - d.life / (d.type === 'ripple' ? 30 : (d.type === 'sparkle' ? 45 : 60));
      const fade = d.opacity * (1 - progress);

      if (d.type === 'drop') {
        d.x += d.vx;
        d.y += d.vy;
        d.vx *= 0.95;
        d.vy *= 0.95;
        d.vy += 0.08; // gravity

        const r = d.radius * (1 - progress * 0.4);

        // Water drop with highlight
        const grad = ctx.createRadialGradient(d.x - r * 0.3, d.y - r * 0.3, 0, d.x, d.y, r);
        grad.addColorStop(0, `rgba(200, 230, 255, ${fade})`);
        grad.addColorStop(0.6, `rgba(167, 211, 243, ${fade * 0.8})`);
        grad.addColorStop(1, `rgba(167, 211, 243, 0)`);
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(d.x, d.y, r, 0, Math.PI * 2);
        ctx.fill();

      } else if (d.type === 'sparkle') {
        d.x += d.vx;
        d.y += d.vy;
        d.vx *= 0.98;

        const twinkle = Math.sin(d.life * 0.5) * 0.5 + 0.5;
        const r = d.radius * twinkle;

        ctx.save();
        ctx.globalAlpha = fade;
        ctx.fillStyle = '#e8e8e8';
        ctx.shadowColor = '#c0c0c0';
        ctx.shadowBlur = 6;
        ctx.beginPath();
        // 4-point star
        for (let j = 0; j < 4; j++) {
          const angle = (Math.PI / 2) * j - Math.PI / 4;
          ctx.lineTo(d.x + Math.cos(angle) * r * 2.5, d.y + Math.sin(angle) * r * 2.5);
          ctx.lineTo(d.x + Math.cos(angle + Math.PI / 4) * r * 0.5, d.y + Math.sin(angle + Math.PI / 4) * r * 0.5);
        }
        ctx.closePath();
        ctx.fill();
        ctx.restore();

      } else if (d.type === 'ripple') {
        const maxR = d.maxRadius || 20;
        d.radius += (maxR - d.radius) * 0.15;

        ctx.beginPath();
        ctx.arc(d.x, d.y, d.radius, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(192, 192, 192, ${fade})`;
        ctx.lineWidth = 1;
        ctx.stroke();
      }
    }

    if (drops.length > 0 || isActive) {
      frameId = requestAnimationFrame(animate);
    } else {
      frameId = 0;
    }
  }

  function startLoop() {
    if (!frameId) frameId = requestAnimationFrame(animate);
  }

  // Touch events
  canvas.style.pointerEvents = 'none';

  document.addEventListener('touchmove', (e) => {
    const touch = e.touches[0];
    if (touch) {
      spawnDrops(touch.clientX, touch.clientY);
      startLoop();
    }
  }, { passive: true });

  document.addEventListener('touchstart', (e) => {
    isActive = true;
    const touch = e.touches[0];
    if (touch) {
      lastX = touch.clientX;
      lastY = touch.clientY;
      // Initial ripple on tap
      drops.push({
        x: touch.clientX, y: touch.clientY,
        radius: 0, maxRadius: 20,
        opacity: 0.25, vx: 0, vy: 0,
        life: 25, type: 'ripple'
      });
      startLoop();
    }
  }, { passive: true });

  document.addEventListener('touchend', () => { isActive = false; });

  // Mouse fallback for desktop
  document.addEventListener('mousemove', (e) => {
    if (isActive) {
      spawnDrops(e.clientX, e.clientY);
      startLoop();
    }
  });
  document.addEventListener('mousedown', (e) => {
    isActive = true;
    lastX = e.clientX;
    lastY = e.clientY;
    drops.push({
      x: e.clientX, y: e.clientY,
      radius: 0, maxRadius: 20,
      opacity: 0.25, vx: 0, vy: 0,
      life: 25, type: 'ripple'
    });
    startLoop();
  });
  document.addEventListener('mouseup', () => { isActive = false; });
</script>

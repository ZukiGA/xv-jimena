---
// Timeline — clean, horizontal on desktop, vertical on mobile
---

<section id="programa" class="py-20 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-[#0a2540] mb-2">Programa</h2>
    <div class="flex items-center justify-center gap-4 mb-12">
      <span class="h-px w-12 bg-[#c0c0c0]/60"></span>
      <span class="text-[#c0c0c0] text-sm">✧</span>
      <span class="h-px w-12 bg-[#c0c0c0]/60"></span>
    </div>

    <div class="space-y-0">
      {[
        { time: '2:00', label: 'PM', title: 'Ceremonia' },
        { time: '7:00', label: 'PM', title: 'Recepción' },
        { time: '8:00', label: 'PM', title: 'Cena' },
        { time: '9:00', label: 'PM', title: 'Vals' },
        { time: '9:30', label: 'PM', title: 'Cambio de Zapatilla' },
        { time: '10:00', label: 'PM', title: 'Brindis' },
        { time: '10:30', label: 'PM', title: 'Fiesta' },
      ].map((item) => (
        <div class="flex items-center py-4 border-b border-[#c0c0c0]/20 last:border-0">
          <div class="w-24 text-right pr-6">
            <span class="text-2xl font-light text-[#0a2540]">{item.time}</span>
            <span class="text-xs font-[Montserrat] text-[#0a2540]/40 ml-1">{item.label}</span>
          </div>
          <div class="w-px h-6 bg-[#c0c0c0]/40"></div>
          <p class="pl-6 text-lg text-[#0a2540]/80 font-light">{item.title}</p>
        </div>
      ))}
    </div>
  </div>
</section>

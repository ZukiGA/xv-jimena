---
// Event details
---

<section id="evento" class="section-photo py-20 px-6" style="background-image: url('/xv-jimena/images/bg/snow-mountain.jpg');">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-white mb-2">Detalles del Evento</h2>
    <div class="flex items-center justify-center gap-4 mb-12">
      <span class="h-px w-12 bg-white/40"></span>
      <span class="text-white/60 text-sm">✧</span>
      <span class="h-px w-12 bg-white/40"></span>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <div class="glass-card p-6">
        <div class="text-4xl mb-4">⛪</div>
        <h3 class="text-lg font-semibold text-white font-[Montserrat] mb-2">Misa de Acción de Gracias</h3>
        <p class="text-white/80 text-sm">Hora por confirmar</p>
        <p class="text-white/60 text-sm mt-1">Parroquia por confirmar</p>
      </div>

      <div class="glass-card p-6">
        <div class="text-4xl mb-4">🏛️</div>
        <h3 class="text-lg font-semibold text-white font-[Montserrat] mb-2">Recepción</h3>
        <p class="text-white/80 text-sm">7:00 PM</p>
        <p class="text-white/60 text-sm mt-1">Salón El Carmen<br>Santo Tomás Hueyotlipan</p>
      </div>

      <div class="glass-card p-6">
        <div class="text-4xl mb-4">🎶</div>
        <h3 class="text-lg font-semibold text-white font-[Montserrat] mb-2">Fiesta</h3>
        <p class="text-white/80 text-sm">Hasta el amanecer ✨</p>
        <p class="text-white/60 text-sm mt-1">Baile, música en vivo<br>y muchas sorpresas</p>
      </div>
    </div>
  </div>
</section>

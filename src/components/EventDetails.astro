---
// Event details
---

<section id="evento" class="py-20 px-6 bg-white/30 backdrop-blur-sm">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-water-deep mb-2">Detalles del Evento</h2>
    <div class="flex items-center justify-center gap-4 mb-12">
      <span class="h-px w-12 bg-silver"></span>
      <span class="text-water-light text-sm">✧</span>
      <span class="h-px w-12 bg-silver"></span>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Ceremony -->
      <div class="p-6 rounded-2xl bg-water-mist/50 border border-water-shimmer/50">
        <div class="text-4xl mb-4">⛪</div>
        <h3 class="text-lg font-semibold text-water-deep font-[Montserrat] mb-2">Misa de Acción de Gracias</h3>
        <p class="text-water-mid text-sm">Hora por confirmar</p>
        <p class="text-water-mid/60 text-sm mt-1">Parroquia por confirmar</p>
      </div>

      <!-- Reception -->
      <div class="p-6 rounded-2xl bg-water-mist/50 border border-water-shimmer/50">
        <div class="text-4xl mb-4">🏛️</div>
        <h3 class="text-lg font-semibold text-water-deep font-[Montserrat] mb-2">Recepción</h3>
        <p class="text-water-mid text-sm">7:00 PM</p>
        <p class="text-water-mid/60 text-sm mt-1">Salón El Carmen<br>Santo Tomás Hueyotlipan</p>
      </div>

      <!-- Party -->
      <div class="p-6 rounded-2xl bg-water-mist/50 border border-water-shimmer/50">
        <div class="text-4xl mb-4">🎶</div>
        <h3 class="text-lg font-semibold text-water-deep font-[Montserrat] mb-2">Fiesta</h3>
        <p class="text-water-mid text-sm">Hasta el amanecer ✨</p>
        <p class="text-water-mid/60 text-sm mt-1">Baile, música en vivo<br>y muchas sorpresas</p>
      </div>
    </div>
  </div>
</section>

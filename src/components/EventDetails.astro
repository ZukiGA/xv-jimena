---
// Event details — minimal, no emojis
---

<section id="evento" class="py-20 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-[#0a2540] mb-2">El Día</h2>
    <div class="flex items-center justify-center gap-4 mb-12">
      <span class="h-px w-12 bg-[#c0c0c0]/60"></span>
      <span class="text-[#c0c0c0] text-sm">✧</span>
      <span class="h-px w-12 bg-[#c0c0c0]/60"></span>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <div class="glass-card p-6">
        <p class="text-xs font-[Montserrat] tracking-[0.3em] uppercase text-[#0a2540]/40 mb-3">Ceremonia</p>
        <h3 class="text-lg font-semibold text-[#0a2540] mb-2">Misa de Acción de Gracias</h3>
        <p class="text-[#0a2540]/80 text-sm">2:00 PM</p>
        <p class="text-[#0a2540]/50 text-sm mt-1">Iglesia de Santo Tomás<br>Hueyotlipan</p>
      </div>

      <div class="glass-card p-6">
        <p class="text-xs font-[Montserrat] tracking-[0.3em] uppercase text-[#0a2540]/40 mb-3">Recepción</p>
        <h3 class="text-lg font-semibold text-[#0a2540] mb-2">Cena y Celebración</h3>
        <p class="text-[#0a2540]/80 text-sm">7:00 PM</p>
        <p class="text-[#0a2540]/50 text-sm mt-1">Salón El Carmen<br>Santo Tomás Hueyotlipan</p>
      </div>

      <div class="glass-card p-6">
        <p class="text-xs font-[Montserrat] tracking-[0.3em] uppercase text-[#0a2540]/40 mb-3">Fiesta</p>
        <h3 class="text-lg font-semibold text-[#0a2540] mb-2">Música y Baile</h3>
        <p class="text-[#0a2540]/80 text-sm">Toda la noche</p>
        <p class="text-[#0a2540]/50 text-sm mt-1">Hasta que el cuerpo aguante</p>
      </div>
    </div>
  </div>
</section>

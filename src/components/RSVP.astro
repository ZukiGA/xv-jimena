---
// RSVP form
---

<section id="confirmar" class="py-20 px-6 bg-fairy-glow/50 backdrop-blur-sm">
  <div class="max-w-xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-water-deep mb-2">Confirmar Asistencia</h2>
    <div class="flex items-center justify-center gap-4 mb-8">
      <span class="h-px w-12 bg-silver"></span>
      <span class="text-water-deep text-sm">✧</span>
      <span class="h-px w-12 bg-silver"></span>
    </div>

    <p class="text-water-mid/70 italic mb-10">
      Por favor confirma tu asistencia antes del <strong class="text-water-deep">10 de Julio de 2026</strong>
    </p>

    <form id="rsvp-form" class="space-y-4 text-left">
      <div>
        <label class="block text-water-deep font-[Montserrat] text-sm mb-1">Nombre completo</label>
        <input
          type="text"
          name="name"
          required
          class="w-full px-4 py-3 rounded-xl bg-white/80 border border-silver-light/80 focus:border-water-mid focus:outline-none transition-colors text-water-deep"
          placeholder="Tu nombre"
        />
      </div>

      <div>
        <label class="block text-water-deep font-[Montserrat] text-sm mb-1">Número de invitados</label>
        <select
          name="guests"
          required
          class="w-full px-4 py-3 rounded-xl bg-white/80 border border-silver-light/80 focus:border-water-mid focus:outline-none transition-colors text-water-deep"
        >
          <option value="">Selecciona</option>
          <option value="1">1 persona</option>
          <option value="2">2 personas</option>
          <option value="3">3 personas</option>
          <option value="4">4 personas</option>
          <option value="5">5+ personas</option>
        </select>
      </div>

      <div>
        <label class="block text-water-deep font-[Montserrat] text-sm mb-1">¿Asistirás?</label>
        <div class="flex gap-4">
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="attending" value="yes" required class="peer hidden" />
            <div class="px-4 py-3 rounded-xl bg-white/80 border border-silver-light/80 text-center peer-checked:bg-water-mid peer-checked:text-white peer-checked:border-water-mid transition-all">
              ¡Ahí estaré! ✨
            </div>
          </label>
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="attending" value="no" class="peer hidden" />
            <div class="px-4 py-3 rounded-xl bg-white/80 border border-silver-light/80 text-center peer-checked:bg-water-mid peer-checked:text-white peer-checked:border-water-mid transition-all">
              No podré ir 😢
            </div>
          </label>
        </div>
      </div>

      <div>
        <label class="block text-water-deep font-[Montserrat] text-sm mb-1">Mensaje para Jimena (opcional)</label>
        <textarea
          name="message"
          rows="3"
          class="w-full px-4 py-3 rounded-xl bg-white/80 border border-silver-light/80 focus:border-water-mid focus:outline-none transition-colors text-water-deep resize-none"
          placeholder="Escribe un mensaje especial..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full py-3 bg-water-mid text-white rounded-xl font-[Montserrat] text-sm tracking-wider hover:bg-water-deep transition-colors"
      >
        Confirmar Asistencia
      </button>
    </form>

    <div id="rsvp-success" class="hidden mt-8 p-6 rounded-2xl bg-white/80 border border-water-light">
      <p class="text-2xl mb-2">✨</p>
      <p class="text-water-deep text-lg">¡Gracias por confirmar!</p>
      <p class="text-water-mid/60 text-sm mt-1">Te esperamos con mucha ilusión</p>
    </div>
  </div>
</section>

<script>
  document.getElementById('rsvp-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    // TODO: Connect to a backend (Google Sheets, Formspree, etc.)
    const form = e.target as HTMLFormElement;
    form.classList.add('hidden');
    document.getElementById('rsvp-success')?.classList.remove('hidden');
  });
</script>

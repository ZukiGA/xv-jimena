---
// RSVP form
---

<section id="confirmar" class="section-photo py-20 px-6" style="background-image: url('/xv-jimena/images/bg/river.jpg');">
  <div class="max-w-xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-white mb-2">Confirmar Asistencia</h2>
    <div class="flex items-center justify-center gap-4 mb-8">
      <span class="h-px w-12 bg-white/40"></span>
      <span class="text-white/60 text-sm">✧</span>
      <span class="h-px w-12 bg-white/40"></span>
    </div>

    <p class="text-white/70 italic mb-10">
      Por favor confirma tu asistencia antes del <strong class="text-white">10 de Julio de 2026</strong>
    </p>

    <form id="rsvp-form" class="glass-card p-6 space-y-4 text-left">
      <div>
        <label class="block text-white font-[Montserrat] text-sm mb-1">Nombre completo</label>
        <input
          type="text"
          name="name"
          required
          class="w-full px-4 py-3 rounded-xl bg-white/20 border border-white/30 focus:border-white/60 focus:outline-none transition-colors text-white placeholder-white/40"
          placeholder="Tu nombre"
        />
      </div>

      <div>
        <label class="block text-white font-[Montserrat] text-sm mb-1">Número de invitados</label>
        <select
          name="guests"
          required
          class="w-full px-4 py-3 rounded-xl bg-white/20 border border-white/30 focus:border-white/60 focus:outline-none transition-colors text-white"
        >
          <option value="" class="text-gray-800">Selecciona</option>
          <option value="1" class="text-gray-800">1 persona</option>
          <option value="2" class="text-gray-800">2 personas</option>
          <option value="3" class="text-gray-800">3 personas</option>
          <option value="4" class="text-gray-800">4 personas</option>
          <option value="5" class="text-gray-800">5+ personas</option>
        </select>
      </div>

      <div>
        <label class="block text-white font-[Montserrat] text-sm mb-1">¿Asistirás?</label>
        <div class="flex gap-4">
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="attending" value="yes" required class="peer hidden" />
            <div class="px-4 py-3 rounded-xl bg-white/10 border border-white/30 text-white text-center peer-checked:bg-white/30 peer-checked:border-white/50 transition-all">
              ¡Ahí estaré! ✨
            </div>
          </label>
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="attending" value="no" class="peer hidden" />
            <div class="px-4 py-3 rounded-xl bg-white/10 border border-white/30 text-white text-center peer-checked:bg-white/30 peer-checked:border-white/50 transition-all">
              No podré ir 😢
            </div>
          </label>
        </div>
      </div>

      <div>
        <label class="block text-white font-[Montserrat] text-sm mb-1">Mensaje para Jimena (opcional)</label>
        <textarea
          name="message"
          rows="3"
          class="w-full px-4 py-3 rounded-xl bg-white/20 border border-white/30 focus:border-white/60 focus:outline-none transition-colors text-white placeholder-white/40 resize-none"
          placeholder="Escribe un mensaje especial..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full py-3 bg-white/25 backdrop-blur-sm text-white border border-white/40 rounded-xl font-[Montserrat] text-sm tracking-wider hover:bg-white/35 transition-colors"
      >
        Confirmar Asistencia
      </button>
    </form>

    <div id="rsvp-success" class="hidden mt-8 glass-card p-6">
      <p class="text-2xl mb-2">✨</p>
      <p class="text-white text-lg">¡Gracias por confirmar!</p>
      <p class="text-white/60 text-sm mt-1">Te esperamos con mucha ilusión</p>
    </div>
  </div>
</section>

<script>
  document.getElementById('rsvp-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    form.classList.add('hidden');
    document.getElementById('rsvp-success')?.classList.remove('hidden');
  });
</script>

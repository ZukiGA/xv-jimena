---
// RSVP form — clean
---

<section id="confirmar" class="py-16 px-6">
  <div class="max-w-md mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-[#0a2540] mb-2">¿Vienes?</h2>
    <div class="flex items-center justify-center mb-8">
      <span class="dew"></span>
    </div>

    <p class="text-[#0a2540]/50 text-sm mb-10">
      Antes del 10 de julio
    </p>

    <form id="rsvp-form" class="space-y-4 text-left">
      <div>
        <input
          type="text"
          name="name"
          required
          class="w-full px-4 py-3 rounded-lg bg-white/30 border border-[#c0c0c0]/40 focus:border-[#0a2540]/30 focus:outline-none transition-colors text-[#0a2540] placeholder-[#0a2540]/30"
          placeholder="¿Cómo te llamas?"
        />
      </div>

      <div>
        <select
          name="guests"
          required
          class="w-full px-4 py-3 rounded-lg bg-white/30 border border-[#c0c0c0]/40 focus:border-[#0a2540]/30 focus:outline-none transition-colors text-[#0a2540]"
        >
          <option value="" class="text-gray-800">¿Cuántos vienen?</option>
          <option value="1" class="text-gray-800">Solo yo</option>
          <option value="2" class="text-gray-800">2</option>
          <option value="3" class="text-gray-800">3</option>
          <option value="4" class="text-gray-800">4</option>
          <option value="5" class="text-gray-800">5+</option>
        </select>
      </div>

      <div>
        <div class="flex gap-3">
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="attending" value="yes" required class="peer hidden" />
            <div class="px-4 py-3 rounded-lg bg-white/20 border border-[#c0c0c0]/30 text-[#0a2540] text-center text-sm peer-checked:bg-white/40 peer-checked:border-[#0a2540]/30 transition-all">
              ¡Ahí estaré!
            </div>
          </label>
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="attending" value="no" class="peer hidden" />
            <div class="px-4 py-3 rounded-lg bg-white/20 border border-[#c0c0c0]/30 text-[#0a2540] text-center text-sm peer-checked:bg-white/40 peer-checked:border-[#0a2540]/30 transition-all">
              No podré ir 😢
            </div>
          </label>
        </div>
      </div>

      <div>
        <textarea
          name="message"
          rows="2"
          class="w-full px-4 py-3 rounded-lg bg-white/20 border border-[#c0c0c0]/30 focus:border-[#0a2540]/30 focus:outline-none transition-colors text-[#0a2540] placeholder-[#0a2540]/30 resize-none"
          placeholder="¿Algo que quieras decirme? 💬"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full py-3 bg-[#0a2540] text-white rounded-lg font-[Montserrat] text-sm tracking-wider hover:bg-[#0a2540]/90 transition-colors"
      >
        Enviar
      </button>
    </form>

    <div id="rsvp-success" class="hidden mt-8">
      <p class="text-[#0a2540] text-lg">¡Gracias! ✨</p>
      <p class="text-[#0a2540]/40 text-sm mt-1">¡Te espero con todo!</p>
    </div>
  </div>
</section>

<script>
  const params = new URLSearchParams(window.location.search);
  const guestName = params.get('n');
  if (guestName) {
    const nameInput = document.querySelector('input[name="name"]') as HTMLInputElement;
    if (nameInput) nameInput.value = decodeURIComponent(guestName.replace(/\+/g, ' '));
  }

  document.getElementById('rsvp-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    const data = {
      name: formData.get('name'),
      guests: formData.get('guests'),
      attending: formData.get('attending'),
      message: formData.get('message') || ''
    };

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.textContent = '...';
    btn.disabled = true;

    try {
      const GOOGLE_SHEETS_URL = 'https://script.google.com/macros/s/AKfycbxIRuGWjZh2CJ8pFlOdjXq2W1OUpjv8muNa1H7TUTg_fJYrlSUcHcjStPo9YW-lVmqhkw/exec';
      
      await fetch(GOOGLE_SHEETS_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      
      form.classList.add('hidden');
      document.getElementById('rsvp-success')?.classList.remove('hidden');
      
      // Water splash burst
      const cx = window.innerWidth / 2;
      const cy = window.innerHeight / 2;
      for (let i = 0; i < 30; i++) {
        const drop = document.createElement('div');
        const angle = (Math.PI * 2 * i) / 30 + (Math.random() - 0.5) * 0.3;
        const dist = 60 + Math.random() * 140;
        const size = 4 + Math.random() * 6;
        const tx = Math.cos(angle) * dist;
        const ty = Math.sin(angle) * dist - 40 - Math.random() * 80; // bias upward
        drop.style.cssText = `
          position:fixed; left:${cx}px; top:${cy}px; width:${size}px; height:${size}px;
          background:radial-gradient(circle, rgba(167,211,243,0.8), rgba(10,80,160,0.3));
          border-radius:50%; z-index:999; pointer-events:none;
          box-shadow: 0 0 ${size * 2}px rgba(120,200,255,0.4);
          transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
          opacity: 1;
        `;
        document.body.appendChild(drop);
        requestAnimationFrame(() => {
          drop.style.transform = `translate(${tx}px, ${ty}px)`;
          drop.style.opacity = '0';
        });
        setTimeout(() => drop.remove(), 1500);
      }
    } catch (err) {
      btn.textContent = 'Enviar';
      btn.disabled = false;
    }
  });
</script>

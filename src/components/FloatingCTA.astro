---
// FloatingCTA — fixed "¿Vienes?" button, hides when RSVP visible or submitted
---

<div id="floating-cta" class="fixed bottom-6 left-0 right-0 z-[60] flex justify-center pointer-events-none opacity-0 translate-y-4 transition-all duration-500">
  <a
    href="#confirmar"
    class="pointer-events-auto px-8 py-3 bg-[#0a2540] text-white rounded-full font-[Montserrat] text-sm tracking-[0.15em] shadow-lg shadow-[#0a2540]/30 hover:bg-[#0a2540]/90 transition-colors flex items-center gap-2 no-underline"
  >
    ¿Vienes?
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7"></path>
    </svg>
  </a>
</div>

<script>
  function initCTA() {
    const cta = document.getElementById('floating-cta');
    const rsvpSection = document.getElementById('confirmar');
    if (!cta || !rsvpSection) return;

    let hidden = false;

    function update() {
      if (hidden) return;

      const scrollY = window.scrollY;
      const showAfter = window.innerHeight * 0.7;
      const rsvpTop = rsvpSection.offsetTop - window.innerHeight;

      if (scrollY > showAfter && scrollY < rsvpTop) {
        cta.style.opacity = '1';
        cta.style.transform = 'translateY(0)';
      } else {
        cta.style.opacity = '0';
        cta.style.transform = 'translateY(16px)';
      }
    }

    cta.querySelector('a')?.addEventListener('click', (e) => {
      e.preventDefault();
      rsvpSection.scrollIntoView({ behavior: 'smooth' });
      // Force reveal the RSVP section
      rsvpSection.classList.add('revealed');
    });

    const form = document.getElementById('rsvp-form');
    if (form) {
      const observer = new MutationObserver(() => {
        if (form.classList.contains('hidden')) {
          hidden = true;
          cta.style.opacity = '0';
          cta.style.transform = 'translateY(16px)';
          setTimeout(() => cta.remove(), 500);
          observer.disconnect();
        }
      });
      observer.observe(form, { attributes: true, attributeFilter: ['class'] });
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCTA);
  } else {
    initCTA();
  }
</script>

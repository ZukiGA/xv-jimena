---
// MagicEntrance — Water portal reveal animation
// Canvas 2D with ripple physics, particles, and cinematic reveal
---

<div id="magic-entrance" class="fixed inset-0 z-[100] bg-black">
  <canvas id="entrance-canvas" class="absolute inset-0 w-full h-full"></canvas>
  
  <!-- Text overlay -->
  <div class="absolute inset-0 flex flex-col items-center justify-center z-10 pointer-events-none">
    <p id="ent-silvermist" class="text-[#c0c0c0]/0 font-[Montserrat] text-xs tracking-[0.4em] uppercase mb-6 transition-all duration-1000">
      Silvermist
    </p>
    <h1 id="ent-name" class="text-7xl md:text-9xl font-light text-white/0 drop-shadow-lg transition-all duration-1000" style="font-family: 'Cormorant Garamond', serif;">
      <span class="ent-letter" style="--i:0">J</span><span class="ent-letter" style="--i:1">i</span><span class="ent-letter" style="--i:2">m</span><span class="ent-letter" style="--i:3">e</span><span class="ent-letter" style="--i:4">n</span><span class="ent-letter" style="--i:5">a</span>
    </h1>
    <span id="ent-xv" class="text-2xl md:text-3xl font-[Montserrat] font-light text-white/0 tracking-[0.5em] mt-3 transition-all duration-1000">
      XV
    </span>
  </div>

  <!-- Skip hint -->
  <button id="ent-skip" class="absolute bottom-8 left-0 right-0 z-20 text-white/20 font-[Montserrat] text-[10px] tracking-[0.3em] uppercase text-center hover:text-white/40 transition-colors">
    toca para continuar
  </button>
</div>

<style>
  .ent-letter {
    display: inline-block;
    opacity: 0;
    transform: translateY(20px);
    filter: blur(8px);
  }
  .ent-letter.reveal {
    animation: letterReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--i) * 0.1s);
  }
  @keyframes letterReveal {
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }
  #magic-entrance.fade-out {
    animation: entranceFadeOut 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes entranceFadeOut {
    0% { opacity: 1; }
    100% { opacity: 0; pointer-events: none; }
  }
</style>

<script>
  // Skip if already seen
  if (sessionStorage.getItem('xv-entrance-seen')) {
    document.getElementById('magic-entrance')?.remove();
  } else {
    const canvas = document.getElementById('entrance-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    let W: number, H: number, cx: number, cy: number;
    let dpr = Math.min(window.devicePixelRatio || 1, 2);
    let startTime = 0;
    let animFrame = 0;
    let phase = 0; // 0=drop, 1=impact, 2=ripple+reveal, 3=text, 4=done

    // --- Resize ---
    function resize() {
      W = window.innerWidth;
      H = window.innerHeight;
      cx = W / 2;
      cy = H / 2;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    // --- Water Drop ---
    const drop = {
      x: 0, y: -40, vy: 0, radius: 6, opacity: 1, active: true,
      trail: [] as { x: number; y: number; opacity: number; radius: number }[]
    };

    // --- Ripples ---
    interface Ripple {
      x: number; y: number; radius: number; maxRadius: number;
      speed: number; opacity: number; lineWidth: number;
    }
    const ripples: Ripple[] = [];

    // --- Particles ---
    interface Particle {
      x: number; y: number; vx: number; vy: number;
      radius: number; opacity: number; color: string;
      life: number; maxLife: number; type: 'splash' | 'sparkle' | 'mist';
    }
    const particles: Particle[] = [];

    // --- Reveal mask ---
    let revealRadius = 0;
    let revealTarget = 0;
    let revealOpacity = 0;

    // --- Create impact effects ---
    function createImpact(x: number, y: number) {
      // Multiple ripple waves with varying speeds
      for (let i = 0; i < 5; i++) {
        ripples.push({
          x, y, radius: 0, maxRadius: Math.max(W, H) * 1.2,
          speed: 3 + i * 1.5, opacity: 0.6 - i * 0.08,
          lineWidth: 3 - i * 0.4
        });
      }

      // Splash particles — water drops going up
      const splashCount = 40;
      for (let i = 0; i < splashCount; i++) {
        const angle = (Math.PI * 2 * i) / splashCount + (Math.random() - 0.5) * 0.3;
        const speed = 2 + Math.random() * 8;
        particles.push({
          x, y,
          vx: Math.cos(angle) * speed * (0.5 + Math.random()),
          vy: -Math.abs(Math.sin(angle) * speed) - Math.random() * 4,
          radius: 1.5 + Math.random() * 3,
          opacity: 0.6 + Math.random() * 0.4,
          color: `hsl(${200 + Math.random() * 20}, ${60 + Math.random() * 30}%, ${70 + Math.random() * 25}%)`,
          life: 0, maxLife: 60 + Math.random() * 40,
          type: 'splash'
        });
      }

      // Sparkle particles — silver/white glitter
      for (let i = 0; i < 60; i++) {
        const angle = Math.random() * Math.PI * 2;
        const speed = 1 + Math.random() * 5;
        particles.push({
          x: x + (Math.random() - 0.5) * 20,
          y: y + (Math.random() - 0.5) * 20,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed - Math.random() * 2,
          radius: 0.5 + Math.random() * 2,
          opacity: Math.random(),
          color: Math.random() > 0.3 ? '#e8e8e8' : '#a7d3f3',
          life: 0, maxLife: 80 + Math.random() * 60,
          type: 'sparkle'
        });
      }

      // Mist particles — slow, large, atmospheric
      for (let i = 0; i < 25; i++) {
        const angle = Math.random() * Math.PI * 2;
        particles.push({
          x: x + (Math.random() - 0.5) * 100,
          y: y + (Math.random() - 0.5) * 100,
          vx: Math.cos(angle) * 0.3,
          vy: -0.2 - Math.random() * 0.5,
          radius: 20 + Math.random() * 40,
          opacity: 0.05 + Math.random() * 0.08,
          color: '#a7d3f3',
          life: 0, maxLife: 120 + Math.random() * 60,
          type: 'mist'
        });
      }
    }

    // --- Ambient sparkles during text reveal ---
    function addAmbientSparkles() {
      for (let i = 0; i < 3; i++) {
        particles.push({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.5,
          vy: -0.3 - Math.random() * 0.5,
          radius: 0.5 + Math.random() * 1.5,
          opacity: Math.random() * 0.6,
          color: Math.random() > 0.5 ? '#c0c0c0' : '#a7d3f3',
          life: 0, maxLife: 60 + Math.random() * 40,
          type: 'sparkle'
        });
      }
    }

    // --- Draw water drop ---
    function drawDrop() {
      if (!drop.active) return;

      // Trail
      for (const t of drop.trail) {
        ctx.beginPath();
        ctx.arc(t.x, t.y, t.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(167, 211, 243, ${t.opacity})`;
        ctx.fill();
      }

      // Main drop — teardrop shape
      ctx.save();
      ctx.translate(drop.x, drop.y);
      ctx.beginPath();
      ctx.moveTo(0, -drop.radius * 1.8);
      ctx.bezierCurveTo(
        drop.radius * 0.8, -drop.radius * 0.5,
        drop.radius, drop.radius * 0.5,
        0, drop.radius
      );
      ctx.bezierCurveTo(
        -drop.radius, drop.radius * 0.5,
        -drop.radius * 0.8, -drop.radius * 0.5,
        0, -drop.radius * 1.8
      );
      ctx.fillStyle = `rgba(167, 211, 243, ${drop.opacity})`;
      ctx.fill();

      // Highlight
      ctx.beginPath();
      ctx.arc(-drop.radius * 0.2, -drop.radius * 0.3, drop.radius * 0.3, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255, 255, 255, ${drop.opacity * 0.6})`;
      ctx.fill();
      ctx.restore();
    }

    // --- Draw ripples ---
    function drawRipples() {
      for (const r of ripples) {
        if (r.opacity <= 0) continue;
        ctx.beginPath();
        ctx.arc(r.x, r.y, r.radius, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(192, 192, 192, ${r.opacity})`;
        ctx.lineWidth = r.lineWidth;
        ctx.stroke();

        // Inner glow
        ctx.beginPath();
        ctx.arc(r.x, r.y, r.radius, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(167, 211, 243, ${r.opacity * 0.3})`;
        ctx.lineWidth = r.lineWidth * 3;
        ctx.stroke();
      }
    }

    // --- Draw particles ---
    function drawParticles() {
      for (const p of particles) {
        if (p.opacity <= 0) continue;
        const progress = p.life / p.maxLife;

        if (p.type === 'sparkle') {
          // Twinkling star shape
          const twinkle = Math.sin(p.life * 0.3) * 0.5 + 0.5;
          const r = p.radius * (0.5 + twinkle * 0.5);
          ctx.save();
          ctx.globalAlpha = p.opacity * (1 - progress);
          ctx.fillStyle = p.color;
          ctx.shadowColor = p.color;
          ctx.shadowBlur = 8;
          ctx.beginPath();
          // 4-point star
          for (let i = 0; i < 4; i++) {
            const angle = (Math.PI / 2) * i;
            ctx.lineTo(p.x + Math.cos(angle) * r * 2, p.y + Math.sin(angle) * r * 2);
            ctx.lineTo(
              p.x + Math.cos(angle + Math.PI / 4) * r * 0.5,
              p.y + Math.sin(angle + Math.PI / 4) * r * 0.5
            );
          }
          ctx.closePath();
          ctx.fill();
          ctx.restore();
        } else if (p.type === 'mist') {
          const gradient = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.radius);
          gradient.addColorStop(0, `rgba(167, 211, 243, ${p.opacity * (1 - progress)})`);
          gradient.addColorStop(1, 'rgba(167, 211, 243, 0)');
          ctx.fillStyle = gradient;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
          ctx.fill();
        } else {
          // Splash
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.radius * (1 - progress * 0.5), 0, Math.PI * 2);
          ctx.fillStyle = p.color;
          ctx.globalAlpha = p.opacity * (1 - progress);
          ctx.fill();
          ctx.globalAlpha = 1;
        }
      }
    }

    // --- Draw reveal mask (dark overlay with circular hole) ---
    function drawReveal() {
      if (revealRadius <= 0) return;
      // We'll use this to fade the black overlay with a circular reveal
      ctx.save();
      ctx.globalCompositeOperation = 'destination-out';
      const gradient = ctx.createRadialGradient(cx, cy, revealRadius * 0.7, cx, cy, revealRadius);
      gradient.addColorStop(0, `rgba(0, 0, 0, ${revealOpacity})`);
      gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
      ctx.fillStyle = gradient;
      ctx.beginPath();
      ctx.arc(cx, cy, revealRadius, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }

    // --- Phase timing ---
    const PHASE_DROP_DURATION = 1200;    // Drop falls
    const PHASE_IMPACT_DELAY = 100;      // Brief pause
    const PHASE_RIPPLE_DURATION = 2000;  // Ripples + reveal
    const PHASE_TEXT_DELAY = 800;        // Text appears
    const PHASE_HOLD = 1500;             // Hold before fade

    // --- Main loop ---
    function animate(timestamp: number) {
      if (!startTime) startTime = timestamp;
      const elapsed = timestamp - startTime;

      ctx.clearRect(0, 0, W, H);

      // Background
      ctx.fillStyle = '#000';
      ctx.fillRect(0, 0, W, H);

      // --- Phase 0: Drop falling ---
      if (phase === 0) {
        drop.x = cx;
        drop.vy += 0.35; // gravity
        drop.y += drop.vy;

        // Trail
        if (drop.trail.length > 12) drop.trail.shift();
        drop.trail.push({
          x: drop.x + (Math.random() - 0.5) * 2,
          y: drop.y - 10,
          opacity: 0.3,
          radius: 2 + Math.random() * 2
        });
        for (const t of drop.trail) {
          t.opacity *= 0.92;
          t.radius *= 0.96;
        }

        drawDrop();

        // Impact when drop reaches center
        if (drop.y >= cy) {
          drop.active = false;
          phase = 1;
          createImpact(cx, cy);
          startTime = timestamp;
        }
      }

      // --- Phase 1: Impact burst ---
      if (phase >= 1) {
        // Update ripples
        for (let i = ripples.length - 1; i >= 0; i--) {
          const r = ripples[i];
          r.radius += r.speed;
          r.opacity *= 0.985;
          r.lineWidth *= 0.998;
          if (r.opacity < 0.01) ripples.splice(i, 1);
        }

        // Update particles
        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          p.x += p.vx;
          p.y += p.vy;
          p.life++;

          if (p.type === 'splash') {
            p.vy += 0.15; // gravity
            p.vx *= 0.98;
          } else if (p.type === 'sparkle') {
            p.vx *= 0.99;
            p.vy *= 0.99;
            p.x += Math.sin(p.life * 0.1) * 0.3;
          } else {
            p.vx *= 0.99;
          }

          if (p.life >= p.maxLife) particles.splice(i, 1);
        }

        // Reveal expansion
        if (phase >= 1 && elapsed > PHASE_IMPACT_DELAY) {
          revealTarget = Math.max(W, H) * 1.5;
          revealOpacity = Math.min(revealOpacity + 0.03, 1);
        }
        revealRadius += (revealTarget - revealRadius) * 0.04;

        // Add ambient sparkles
        if (phase >= 2 && Math.random() > 0.7) {
          addAmbientSparkles();
        }

        drawRipples();
        drawParticles();
        drawReveal();

        // Transition to text phase
        if (phase === 1 && elapsed > PHASE_RIPPLE_DURATION) {
          phase = 2;
          startTime = timestamp;

          // Reveal text
          const silvermist = document.getElementById('ent-silvermist');
          if (silvermist) silvermist.style.color = 'rgba(192, 192, 192, 0.8)';

          setTimeout(() => {
            document.querySelectorAll('.ent-letter').forEach(l => l.classList.add('reveal'));
          }, 300);

          setTimeout(() => {
            const xv = document.getElementById('ent-xv');
            if (xv) xv.style.color = 'rgba(255, 255, 255, 0.8)';
          }, 1200);
        }

        // Fade out
        if (phase === 2 && elapsed > PHASE_TEXT_DELAY + PHASE_HOLD) {
          phase = 3;
          const entrance = document.getElementById('magic-entrance');
          if (entrance) {
            entrance.classList.add('fade-out');
            sessionStorage.setItem('xv-entrance-seen', '1');
            setTimeout(() => entrance.remove(), 1300);
          }
        }
      }

      if (phase < 3) {
        animFrame = requestAnimationFrame(animate);
      }
    }

    // Start after a brief black moment
    setTimeout(() => {
      animFrame = requestAnimationFrame(animate);
    }, 400);

    // Skip on tap
    function skipEntrance() {
      cancelAnimationFrame(animFrame);
      const entrance = document.getElementById('magic-entrance');
      if (entrance) {
        entrance.classList.add('fade-out');
        sessionStorage.setItem('xv-entrance-seen', '1');
        setTimeout(() => entrance.remove(), 500);
      }
    }

    document.getElementById('ent-skip')?.addEventListener('click', skipEntrance);
    document.getElementById('magic-entrance')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id !== 'ent-skip') {
        // Only skip after drop has fallen
        if (phase >= 1) skipEntrance();
      }
    });
  }
</script>

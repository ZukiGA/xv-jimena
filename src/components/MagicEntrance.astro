---
// MagicEntrance — Water portal reveal animation (v2)
// Faster, no text duplication, syncs with hero
---

<div id="magic-entrance" class="fixed inset-0 z-[100]">
  <canvas id="entrance-canvas" class="absolute inset-0 w-full h-full"></canvas>
  
  <!-- Text overlay — same positions as Hero -->
  <div class="absolute inset-0 pointer-events-none">
    <!-- Silvermist — same as Hero top-8 -->
    <div class="absolute top-8 left-0 right-0 z-10 px-6 text-center">
      <div class="flex items-center justify-center gap-4 mb-3">
        <span class="h-px w-10 ent-line"></span>
        <span class="text-sm ent-decor">✧</span>
        <span class="h-px w-10 ent-line"></span>
      </div>
      <p class="font-[Montserrat] text-xs tracking-[0.4em] uppercase ent-text" data-delay="1.8">
        Silvermist
      </p>
    </div>

    <!-- Jimena XV — same as Hero top-[17%] -->
    <div class="absolute top-[17%] left-0 right-0 z-10 px-6 text-center">
      <h1 class="text-7xl md:text-9xl font-light mb-3 drop-shadow-lg" style="font-family: 'Cormorant Garamond', serif;">
        <span class="ent-letter" style="--i:0">J</span><span class="ent-letter" style="--i:1">i</span><span class="ent-letter" style="--i:2">m</span><span class="ent-letter" style="--i:3">e</span><span class="ent-letter" style="--i:4">n</span><span class="ent-letter" style="--i:5">a</span>
      </h1>
      <span class="text-2xl md:text-3xl font-[Montserrat] font-light tracking-[0.5em] ent-text" data-delay="2.2">
        XV
      </span>
    </div>

    <!-- Date — same as Hero bottom-5 -->
    <div class="absolute bottom-5 left-0 right-0 z-10 px-6 text-center">
      <p class="font-[Montserrat] text-sm tracking-[0.25em] ent-text" data-delay="2.5">
        25 · 07 · 2026
      </p>
      <p class="font-[Montserrat] text-xs mt-2 tracking-wider ent-text" data-delay="2.7">
        Santo Tomás Hueyotlipan, Puebla
      </p>
    </div>
  </div>
</div>

<style>
  .ent-letter {
    display: inline-block;
    opacity: 0;
    transform: translateY(20px);
    filter: blur(8px);
    color: white;
  }
  .ent-letter.reveal {
    animation: letterReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--i) * 0.1s);
  }
  @keyframes letterReveal {
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }
  .ent-text {
    color: transparent;
    transition: color 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ent-text.show { color: rgba(255, 255, 255, 0.8); }
  .ent-text.show-silver { color: rgba(192, 192, 192, 0.8); }
  .ent-line {
    background-color: transparent;
    transition: background-color 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ent-line.show { background-color: rgba(192, 192, 192, 0.4); }
  .ent-decor {
    color: transparent;
    transition: color 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ent-decor.show { color: rgba(192, 192, 192, 0.5); }
  #magic-entrance.fade-out {
    animation: entranceFadeOut 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes entranceFadeOut {
    0% { opacity: 1; }
    100% { opacity: 0; pointer-events: none; }
  }
</style>

<script>
  // Skip if already seen
  if (sessionStorage.getItem('xv-entrance-seen')) {
    document.getElementById('magic-entrance')?.remove();
  } else {
    const canvas = document.getElementById('entrance-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    let W: number, H: number, cx: number, cy: number;
    let dpr = Math.min(window.devicePixelRatio || 1, 2);
    let startTime = 0;
    let animFrame = 0;
    let phase = 0; // 0=drop, 1=impact+reveal, 2=done

    function resize() {
      W = window.innerWidth;
      H = window.innerHeight;
      cx = W / 2;
      cy = H / 2;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    // --- Water Drop ---
    const drop = {
      x: 0, y: -30, vy: 0, radius: 5, active: true,
      trail: [] as { x: number; y: number; opacity: number; radius: number }[]
    };

    // --- Ripples ---
    interface Ripple {
      x: number; y: number; radius: number;
      speed: number; opacity: number; lineWidth: number;
    }
    const ripples: Ripple[] = [];

    // --- Particles ---
    interface Particle {
      x: number; y: number; vx: number; vy: number;
      radius: number; opacity: number; color: string;
      life: number; maxLife: number; type: 'splash' | 'sparkle' | 'mist';
    }
    const particles: Particle[] = [];

    // --- Overlay opacity (1 = fully black, 0 = transparent) ---
    let overlayAlpha = 1;

    function createImpact(x: number, y: number) {
      // Trigger text reveals
      setTimeout(() => {
        document.querySelectorAll('.ent-letter').forEach(l => l.classList.add('reveal'));
      }, 400);
      setTimeout(() => {
        document.querySelectorAll('.ent-line').forEach(el => el.classList.add('show'));
        document.querySelectorAll('.ent-decor').forEach(el => el.classList.add('show'));
        // Silvermist gets silver color, rest gets white
        document.querySelectorAll('.ent-text').forEach(el => {
          const text = el.textContent?.trim();
          if (text === 'Silvermist') {
            el.classList.add('show-silver');
          } else {
            el.classList.add('show');
          }
        });
      }, 800);

      // Ripple waves
      for (let i = 0; i < 4; i++) {
        ripples.push({
          x, y, radius: 0,
          speed: 5 + i * 2, opacity: 0.5 - i * 0.1,
          lineWidth: 2.5 - i * 0.4
        });
      }

      // Splash particles
      for (let i = 0; i < 30; i++) {
        const angle = (Math.PI * 2 * i) / 30 + (Math.random() - 0.5) * 0.3;
        const speed = 3 + Math.random() * 7;
        particles.push({
          x, y,
          vx: Math.cos(angle) * speed,
          vy: -Math.abs(Math.sin(angle) * speed) - Math.random() * 3,
          radius: 1.5 + Math.random() * 2.5,
          opacity: 0.7 + Math.random() * 0.3,
          color: `hsl(${200 + Math.random() * 20}, ${60 + Math.random() * 30}%, ${70 + Math.random() * 25}%)`,
          life: 0, maxLife: 40 + Math.random() * 30,
          type: 'splash'
        });
      }

      // Sparkles
      for (let i = 0; i < 50; i++) {
        const angle = Math.random() * Math.PI * 2;
        const speed = 0.8 + Math.random() * 4;
        particles.push({
          x: x + (Math.random() - 0.5) * 30,
          y: y + (Math.random() - 0.5) * 30,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed - Math.random() * 1.5,
          radius: 0.5 + Math.random() * 2,
          opacity: 0.3 + Math.random() * 0.7,
          color: Math.random() > 0.3 ? '#e8e8e8' : '#a7d3f3',
          life: 0, maxLife: 60 + Math.random() * 40,
          type: 'sparkle'
        });
      }

      // Mist
      for (let i = 0; i < 15; i++) {
        const angle = Math.random() * Math.PI * 2;
        particles.push({
          x: x + (Math.random() - 0.5) * 80,
          y: y + (Math.random() - 0.5) * 80,
          vx: Math.cos(angle) * 0.3,
          vy: -0.3 - Math.random() * 0.4,
          radius: 25 + Math.random() * 35,
          opacity: 0.04 + Math.random() * 0.06,
          color: '#a7d3f3',
          life: 0, maxLife: 80 + Math.random() * 40,
          type: 'mist'
        });
      }
    }

    function drawDrop() {
      if (!drop.active) return;

      // Trail
      for (const t of drop.trail) {
        ctx.beginPath();
        ctx.arc(t.x, t.y, t.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(167, 211, 243, ${t.opacity})`;
        ctx.fill();
      }

      // Teardrop
      ctx.save();
      ctx.translate(drop.x, drop.y);
      ctx.beginPath();
      ctx.moveTo(0, -drop.radius * 1.8);
      ctx.bezierCurveTo(
        drop.radius * 0.8, -drop.radius * 0.5,
        drop.radius, drop.radius * 0.5,
        0, drop.radius
      );
      ctx.bezierCurveTo(
        -drop.radius, drop.radius * 0.5,
        -drop.radius * 0.8, -drop.radius * 0.5,
        0, -drop.radius * 1.8
      );
      ctx.fillStyle = `rgba(167, 211, 243, 1)`;
      ctx.fill();

      // Highlight
      ctx.beginPath();
      ctx.arc(-drop.radius * 0.2, -drop.radius * 0.3, drop.radius * 0.3, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255, 255, 255, 0.6)';
      ctx.fill();
      ctx.restore();
    }

    function drawRipples() {
      for (const r of ripples) {
        if (r.opacity <= 0) continue;
        ctx.beginPath();
        ctx.arc(r.x, r.y, r.radius, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(192, 192, 192, ${r.opacity})`;
        ctx.lineWidth = r.lineWidth;
        ctx.stroke();

        ctx.beginPath();
        ctx.arc(r.x, r.y, r.radius, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(167, 211, 243, ${r.opacity * 0.3})`;
        ctx.lineWidth = r.lineWidth * 3;
        ctx.stroke();
      }
    }

    function drawParticles() {
      for (const p of particles) {
        if (p.opacity <= 0) continue;
        const progress = p.life / p.maxLife;
        const fadeOut = 1 - progress;

        if (p.type === 'sparkle') {
          const twinkle = Math.sin(p.life * 0.3) * 0.5 + 0.5;
          const r = p.radius * (0.5 + twinkle * 0.5);
          ctx.save();
          ctx.globalAlpha = p.opacity * fadeOut;
          ctx.fillStyle = p.color;
          ctx.shadowColor = p.color;
          ctx.shadowBlur = 8;
          ctx.beginPath();
          for (let i = 0; i < 4; i++) {
            const angle = (Math.PI / 2) * i;
            ctx.lineTo(p.x + Math.cos(angle) * r * 2, p.y + Math.sin(angle) * r * 2);
            ctx.lineTo(
              p.x + Math.cos(angle + Math.PI / 4) * r * 0.5,
              p.y + Math.sin(angle + Math.PI / 4) * r * 0.5
            );
          }
          ctx.closePath();
          ctx.fill();
          ctx.restore();
        } else if (p.type === 'mist') {
          const gradient = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.radius);
          gradient.addColorStop(0, `rgba(167, 211, 243, ${p.opacity * fadeOut})`);
          gradient.addColorStop(1, 'rgba(167, 211, 243, 0)');
          ctx.fillStyle = gradient;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
          ctx.fill();
        } else {
          ctx.globalAlpha = p.opacity * fadeOut;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.radius * (1 - progress * 0.5), 0, Math.PI * 2);
          ctx.fillStyle = p.color;
          ctx.fill();
          ctx.globalAlpha = 1;
        }
      }
    }

    // Show skip hint after 3 seconds
    setTimeout(() => {
      const skip = document.getElementById('ent-skip');
      if (skip) skip.style.color = 'rgba(255, 255, 255, 0.2)';
    }, 3000);

    function endEntrance() {
      cancelAnimationFrame(animFrame);
      const entrance = document.getElementById('magic-entrance');
      if (entrance) {
        entrance.classList.add('fade-out');
        sessionStorage.setItem('xv-entrance-seen', '1');
        setTimeout(() => entrance.remove(), 900);
      }
    }

    function animate(timestamp: number) {
      if (!startTime) startTime = timestamp;
      const elapsed = timestamp - startTime;

      ctx.clearRect(0, 0, W, H);

      // Black overlay — fades out after impact
      if (overlayAlpha > 0) {
        ctx.fillStyle = `rgba(0, 0, 0, ${overlayAlpha})`;
        ctx.fillRect(0, 0, W, H);
      }

      // --- Phase 0: Drop falling (faster) ---
      if (phase === 0) {
        drop.x = cx;
        drop.vy += 0.6; // faster gravity
        drop.y += drop.vy;

        if (drop.trail.length > 8) drop.trail.shift();
        drop.trail.push({
          x: drop.x + (Math.random() - 0.5) * 2,
          y: drop.y - 8,
          opacity: 0.3,
          radius: 1.5 + Math.random() * 1.5
        });
        for (const t of drop.trail) {
          t.opacity *= 0.9;
          t.radius *= 0.95;
        }

        drawDrop();

        if (drop.y >= cy) {
          drop.active = false;
          phase = 1;
          createImpact(cx, cy);
          startTime = timestamp;
        }
      }

      // --- Phase 1: Impact + fade overlay to reveal hero ---
      if (phase >= 1) {
        // Fade out black overlay to reveal hero behind
        overlayAlpha = Math.max(0, overlayAlpha - 0.025);

        // Update ripples
        for (let i = ripples.length - 1; i >= 0; i--) {
          const r = ripples[i];
          r.radius += r.speed;
          r.opacity *= 0.982;
          r.lineWidth *= 0.997;
          if (r.opacity < 0.01) ripples.splice(i, 1);
        }

        // Update particles
        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          p.x += p.vx;
          p.y += p.vy;
          p.life++;

          if (p.type === 'splash') {
            p.vy += 0.18;
            p.vx *= 0.97;
          } else if (p.type === 'sparkle') {
            p.vx *= 0.99;
            p.vy *= 0.99;
            p.x += Math.sin(p.life * 0.1) * 0.3;
          } else {
            p.vx *= 0.99;
          }

          if (p.life >= p.maxLife) particles.splice(i, 1);
        }

        // Add ambient sparkles while fading
        if (overlayAlpha > 0.1 && Math.random() > 0.8) {
          for (let i = 0; i < 2; i++) {
            particles.push({
              x: Math.random() * W,
              y: Math.random() * H,
              vx: (Math.random() - 0.5) * 0.4,
              vy: -0.2 - Math.random() * 0.4,
              radius: 0.5 + Math.random() * 1.5,
              opacity: Math.random() * 0.5,
              color: Math.random() > 0.5 ? '#c0c0c0' : '#a7d3f3',
              life: 0, maxLife: 50 + Math.random() * 30,
              type: 'sparkle'
            });
          }
        }

        drawRipples();
        drawParticles();

        // End when overlay fully transparent and particles mostly gone
        if (overlayAlpha <= 0 && particles.length < 10) {
          endEntrance();
          return;
        }
      }

      animFrame = requestAnimationFrame(animate);
    }

    // Start after brief black
    setTimeout(() => {
      animFrame = requestAnimationFrame(animate);
    }, 300);

    // Tap anywhere to skip (after impact)
    document.getElementById('magic-entrance')?.addEventListener('click', () => {
      if (phase >= 1) endEntrance();
    });
  }
</script>

---
// Photo divider — full-width image between content sections
interface Props {
  src: string;
  alt?: string;
  height?: string;
}
const { src, alt = '', height = 'h-[50vh]' } = Astro.props;
---

<div class={`relative ${height} overflow-hidden`}>
  <img
    src={src}
    alt={alt}
    class="w-full h-full object-cover"
    loading="lazy"
  />
</div>

---
// Photo divider — parallax full-width image
interface Props {
  src: string;
  alt?: string;
  height?: string;
}
const { src, alt = '', height = 'h-[50vh]' } = Astro.props;
---

<div class={`photo-divider relative ${height} overflow-hidden`}>
  <img
    src={src}
    alt={alt}
    class="photo-divider-img absolute inset-0 w-full object-cover will-change-transform"
    loading="lazy"
    style="height: 130%; top: -15%;"
  />
</div>

---
// Location with map
---

<section id="ubicacion" class="py-20 px-6 bg-white/30 backdrop-blur-sm">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-water-deep mb-2">Ubicación</h2>
    <div class="flex items-center justify-center gap-4 mb-12">
      <span class="h-px w-12 bg-silver"></span>
      <span class="text-water-light text-sm">✧</span>
      <span class="h-px w-12 bg-silver"></span>
    </div>

    <div class="mb-8">
      <h3 class="text-xl text-water-deep font-semibold mb-1">Salón El Carmen</h3>
      <p class="text-water-mid/70">Santo Tomás Hueyotlipan, Puebla</p>
    </div>

    <!-- Map embed -->
    <div class="rounded-2xl overflow-hidden border border-water-shimmer/50 shadow-lg mb-8">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3770.0!2d-98.35!3d19.15!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTnCsDA5JzAwLjAiTiA5OMKwMjEnMDAuMCJX!5e0!3m2!1ses!2smx!4v1"
        width="100%"
        height="350"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>

    <a
      href="https://maps.google.com/?q=Salon+El+Carmen+Santo+Tomas+Hueyotlipan"
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 px-6 py-3 bg-water-mid text-white rounded-full font-[Montserrat] text-sm tracking-wider hover:bg-water-deep transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
      Cómo llegar
    </a>
  </div>
</section>

---
// Location — big "Llévame" CTA, no confusing embed
---

<section id="ubicacion" class="py-20 px-6">
  <div class="max-w-xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-light text-[#0a2540] mb-2">¿Dónde es?</h2>
    <div class="flex items-center justify-center gap-0 mb-12">
      <span class="h-px w-12 bg-[#c0c0c0]/60"></span>
      <span class="h-px w-12 bg-[#c0c0c0]/60"></span>
    </div>

    <!-- Venue info -->
    <div class="glass-card p-6 mb-8">
      <svg class="w-8 h-8 mx-auto mb-3 text-[#0a2540]/30" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
      <h3 class="text-xl text-[#0a2540] font-semibold mb-2">Salón Jardín El Carmen</h3>
      <p class="text-[#0a2540]/50 text-sm leading-relaxed">
        Calle 8 Sur 678, 75280<br>
        Santo Tomás Hueyotlipan, Puebla
      </p>
    </div>

    <!-- BIG CTA -->
    <a
      href="https://maps.app.goo.gl/dai3pkLxuVn5rnMT8"
      target="_blank"
      rel="noopener"
      class="group inline-flex flex-col items-center px-8 py-4 bg-white/20 backdrop-blur-sm text-[#0a2540] no-underline border border-[#c0c0c0]/30 rounded-2xl font-[Montserrat] text-sm tracking-wider hover:bg-white/30 transition-all hover:scale-[1.02] shadow-lg shadow-black/5"
    >
      <div class="flex items-center justify-center gap-3">
        <svg class="w-6 h-6 shrink-0 group-hover:animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <span>Llévame al Salón</span>
      </div>
      <p class="text-[#0a2540]/40 text-xs mt-1">Abre en Google Maps</p>
    </a>
  </div>
</section>

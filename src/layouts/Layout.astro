---
// Main layout
interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const { title, description = 'XV Años de Jimena — 25 de Julio 2026', lang = 'es' } = Astro.props;
const ogImage = `${Astro.site}images/bg/hero-mountain.jpg`;
const pageUrl = `${Astro.site}`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- OG Tags -->
    <meta property="og:title" content="XV Años de Jimena ✨🧚" />
    <meta property="og:description" content="Estás invitada(o) a celebrar los XV Años de Jimena — 25 de Julio 2026 💧" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content="website" />

    <!-- Twitter/WhatsApp -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="XV Años de Jimena ✨🧚" />
    <meta name="twitter:description" content="Estás invitada(o) a celebrar los XV Años de Jimena — 25 de Julio 2026 💧" />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="antialiased overflow-x-hidden">
    <slot />

    <!-- Global animation styles (must not be scoped) -->
    <style is:global>
      @keyframes dropFall {
        0% { transform: translateY(-100vh); opacity: 0; }
        10% { opacity: 0.7; }
        90% { opacity: 0.5; }
        100% { transform: translateY(100vh); opacity: 0; }
      }
      .water-drop {
        position: fixed;
        top: 0;
        width: 3px;
        height: 12px;
        background: linear-gradient(to bottom, transparent, rgba(10, 80, 160, 0.5));
        border-radius: 50%;
        box-shadow: 0 0 4px rgba(10, 80, 160, 0.3);
        animation: dropFall linear infinite;
        pointer-events: none;
        z-index: 9998;
      }
      @keyframes rippleExpand {
        0% { transform: translate(-50%, -50%) scale(0); opacity: 0.5; }
        100% { transform: translate(-50%, -50%) scale(1); opacity: 0; }
      }
      .ripple-effect {
        position: fixed;
        width: 150px;
        height: 150px;
        border-radius: 50%;
        border: 2px solid rgba(120, 200, 255, 0.6);
        box-shadow: 0 0 10px rgba(120, 200, 255, 0.3);
        animation: rippleExpand 1s ease-out forwards;
        pointer-events: none;
        z-index: 9997;
      }
      @keyframes confettiFall {
        0% { transform: translateY(-100%) rotate(0deg); opacity: 1; }
        100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
      }
      .confetti-piece {
        position: fixed;
        width: 8px;
        height: 12px;
        top: -20px;
        z-index: 999;
        animation: confettiFall 3s ease-in forwards;
        pointer-events: none;
      }
      @keyframes fairyDust {
        0% { text-shadow: 0 0 5px rgba(120, 200, 255, 0.5); }
        50% { text-shadow: 0 0 20px rgba(120, 200, 255, 0.8), 0 0 40px rgba(180, 220, 255, 0.4); }
        100% { text-shadow: 0 0 5px rgba(120, 200, 255, 0.5); }
      }
      .fairy-glow-active {
        animation: fairyDust 1.5s ease-in-out infinite;
      }
    </style>

    <!-- Floating music button -->
    <button
      id="music-btn"
      class="fixed bottom-6 right-6 z-50 w-12 h-12 rounded-full bg-white/20 backdrop-blur-md border border-[#c0c0c0]/50 flex items-center justify-center text-white text-xl hover:bg-white/30 transition-all shadow-lg"
      aria-label="Reproducir música"
    >
      🎵
    </button>
    <audio id="bg-music" src="/audio/la-separacion.mp3" loop preload="none"></audio>

    <!-- Personalized name + WhatsApp share -->
    <script>
      // Read ?n= param for personalized greeting
      const params = new URLSearchParams(window.location.search);
      const invitado = params.get('n');
      if (invitado) {
        const nameEl = document.getElementById('guest-name');
        const wrapEl = document.getElementById('greeting-wrap');
        if (nameEl) {
          nameEl.textContent = decodeURIComponent(invitado.replace(/\+/g, ' '));
          wrapEl?.classList.remove('hidden');
        }
      }

      // Music player
      const musicBtn = document.getElementById('music-btn');
      const audio = document.getElementById('bg-music') as HTMLAudioElement;
      let musicPlaying = false;

      musicBtn?.addEventListener('click', () => {
        if (!audio) return;
        if (!musicPlaying) {
          audio.play();
          if (musicBtn) musicBtn.textContent = '🔇';
          musicPlaying = true;
        } else {
          audio.pause();
          if (musicBtn) musicBtn.textContent = '🎵';
          musicPlaying = false;
        }
      });

      // Water drops animation
      function createDrop() {
        const drop = document.createElement('div');
        drop.classList.add('water-drop');
        drop.style.left = Math.random() * 100 + 'vw';
        drop.style.animationDuration = (3 + Math.random() * 4) + 's';
        drop.style.animationDelay = Math.random() * 2 + 's';
        document.body.appendChild(drop);
        setTimeout(() => drop.remove(), 8000);
      }
      // Create drops periodically
      setInterval(createDrop, 600);
      for (let i = 0; i < 8; i++) setTimeout(createDrop, i * 200);

      // Ripple on tap/click
      function doRipple(x: number, y: number) {
        const ripple = document.createElement('div');
        ripple.classList.add('ripple-effect');
        ripple.style.left = x + 'px';
        ripple.style.top = y + 'px';
        document.body.appendChild(ripple);
        setTimeout(() => ripple.remove(), 1000);
      }
      document.addEventListener('click', (e) => doRipple(e.clientX, e.clientY));
      document.addEventListener('touchstart', (e) => {
        const t = e.touches[0];
        if (t) doRipple(t.clientX, t.clientY);
      }, { passive: true });

      // Confetti on RSVP success
      function launchConfetti() {
        const colors = ['#3aacff', '#0c8ce9', '#ffffff', '#a7d3f3', '#8ec5ed', '#c0c0c0'];
        for (let i = 0; i < 60; i++) {
          const piece = document.createElement('div');
          piece.classList.add('confetti-piece');
          piece.style.left = Math.random() * 100 + 'vw';
          piece.style.background = colors[Math.floor(Math.random() * colors.length)];
          piece.style.animationDelay = Math.random() * 1.5 + 's';
          piece.style.animationDuration = (2 + Math.random() * 2) + 's';
          piece.style.transform = `rotate(${Math.random() * 360}deg)`;
          document.body.appendChild(piece);
          setTimeout(() => piece.remove(), 5000);
        }
      }
      // Hook into RSVP success
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((m) => {
          const target = m.target as HTMLElement;
          if (target.id === 'rsvp-success' && !target.classList.contains('hidden')) {
            launchConfetti();
          }
        });
      });
      const rsvpSuccess = document.getElementById('rsvp-success');
      if (rsvpSuccess) observer.observe(rsvpSuccess, { attributes: true, attributeFilter: ['class'] });

      // Easter egg: triple tap on "Silvermist" text
      let tapCount = 0;
      let tapTimer: any;
      document.querySelectorAll('*').forEach(el => {
        if (el.textContent?.trim() === 'Silvermist') {
          el.addEventListener('click', (e) => {
            e.stopPropagation();
            tapCount++;
            clearTimeout(tapTimer);
            tapTimer = setTimeout(() => { tapCount = 0; }, 500);
            if (tapCount >= 3) {
              tapCount = 0;
              // Fairy dust effect
              document.querySelectorAll('h1, h2').forEach(h => h.classList.add('fairy-glow-active'));
              // Create fairy sparkles
              for (let i = 0; i < 30; i++) {
                const spark = document.createElement('div');
                spark.classList.add('sparkle');
                spark.style.left = Math.random() * 100 + '%';
                spark.style.top = Math.random() * 100 + '%';
                spark.style.position = 'fixed';
                spark.style.zIndex = '9999';
                spark.style.width = '6px';
                spark.style.height = '6px';
                spark.style.background = '#78c8ff';
                spark.style.boxShadow = '0 0 10px #78c8ff';
                document.body.appendChild(spark);
                setTimeout(() => spark.remove(), 3000);
              }
              setTimeout(() => {
                document.querySelectorAll('.fairy-glow-active').forEach(h => h.classList.remove('fairy-glow-active'));
              }, 5000);
            }
          });
        }
      });
    </script>
  </body>
</html>

<style>
  @import '../styles/global.css';
</style>

---
// Main layout
interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const { title, description = 'XV Años de Jimena — 25 de Julio 2026', lang = 'es' } = Astro.props;
const ogImage = `${Astro.site}xv-jimena/images/bg/hero-mountain.jpg`;
const pageUrl = `${Astro.site}xv-jimena/`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- OG Tags -->
    <meta property="og:title" content="XV Años de Jimena ✨🧚" />
    <meta property="og:description" content="Estás invitada(o) a celebrar los XV Años de Jimena — 25 de Julio 2026 💧" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content="website" />

    <!-- Twitter/WhatsApp -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="XV Años de Jimena ✨🧚" />
    <meta name="twitter:description" content="Estás invitada(o) a celebrar los XV Años de Jimena — 25 de Julio 2026 💧" />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="antialiased overflow-x-hidden">
    <slot />

    <!-- Floating music button -->
    <button
      id="music-btn"
      class="fixed bottom-6 right-6 z-50 w-12 h-12 rounded-full bg-white/20 backdrop-blur-md border border-white/30 flex items-center justify-center text-white text-xl hover:bg-white/30 transition-all shadow-lg"
      aria-label="Reproducir música"
    >
      🎵
    </button>
    <div id="yt-player-wrap" class="fixed bottom-20 right-6 z-50 hidden rounded-xl overflow-hidden shadow-2xl border border-white/20">
      <div id="yt-player"></div>
    </div>

    <!-- Personalized name + WhatsApp share -->
    <script>
      // Read ?n= param for personalized greeting
      const params = new URLSearchParams(window.location.search);
      const invitado = params.get('n');
      if (invitado) {
        const nameEl = document.getElementById('guest-name');
        if (nameEl) {
          nameEl.textContent = decodeURIComponent(invitado.replace(/\+/g, ' '));
          nameEl.parentElement?.classList.remove('hidden');
        }
      }

      // YouTube IFrame API
      let player: any = null;
      let musicPlaying = false;
      const musicBtn = document.getElementById('music-btn');
      const playerWrap = document.getElementById('yt-player-wrap');

      // Load YT API
      const tag = document.createElement('script');
      tag.src = 'https://www.youtube.com/iframe_api';
      document.head.appendChild(tag);

      (window as any).onYouTubeIframeAPIReady = () => {
        player = new (window as any).YT.Player('yt-player', {
          height: '1',
          width: '1',
          videoId: '8a2gCnF2Nq4',
          playerVars: { autoplay: 0, loop: 1, playlist: '8a2gCnF2Nq4', controls: 0 },
          events: {
            onReady: () => console.log('YT player ready'),
            onStateChange: (e: any) => {
              if (e.data === 0) player.playVideo(); // loop
            }
          }
        });
      };

      musicBtn?.addEventListener('click', () => {
        if (!player) return;
        if (!musicPlaying) {
          player.playVideo();
          if (musicBtn) musicBtn.textContent = '🔇';
          musicPlaying = true;
        } else {
          player.pauseVideo();
          if (musicBtn) musicBtn.textContent = '🎵';
          musicPlaying = false;
        }
      });

      // Water drops animation
      function createDrop() {
        const drop = document.createElement('div');
        drop.classList.add('water-drop');
        drop.style.left = Math.random() * 100 + '%';
        drop.style.animationDuration = (3 + Math.random() * 4) + 's';
        drop.style.animationDelay = Math.random() * 2 + 's';
        document.body.appendChild(drop);
        setTimeout(() => drop.remove(), 8000);
      }
      // Create drops periodically
      setInterval(createDrop, 800);
      for (let i = 0; i < 5; i++) setTimeout(createDrop, i * 300);

      // Ripple on click
      document.addEventListener('click', (e) => {
        const ripple = document.createElement('div');
        ripple.classList.add('ripple-effect');
        ripple.style.left = e.clientX + 'px';
        ripple.style.top = e.clientY + 'px';
        document.body.appendChild(ripple);
        setTimeout(() => ripple.remove(), 1000);
      });

      // Confetti on RSVP success
      function launchConfetti() {
        const colors = ['#3aacff', '#0c8ce9', '#ffffff', '#a7d3f3', '#8ec5ed', '#c0c0c0'];
        for (let i = 0; i < 60; i++) {
          const piece = document.createElement('div');
          piece.classList.add('confetti-piece');
          piece.style.left = Math.random() * 100 + 'vw';
          piece.style.background = colors[Math.floor(Math.random() * colors.length)];
          piece.style.animationDelay = Math.random() * 1.5 + 's';
          piece.style.animationDuration = (2 + Math.random() * 2) + 's';
          piece.style.transform = `rotate(${Math.random() * 360}deg)`;
          document.body.appendChild(piece);
          setTimeout(() => piece.remove(), 5000);
        }
      }
      // Hook into RSVP success
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((m) => {
          const target = m.target as HTMLElement;
          if (target.id === 'rsvp-success' && !target.classList.contains('hidden')) {
            launchConfetti();
          }
        });
      });
      const rsvpSuccess = document.getElementById('rsvp-success');
      if (rsvpSuccess) observer.observe(rsvpSuccess, { attributes: true, attributeFilter: ['class'] });

      // Easter egg: triple tap on "Silvermist" text
      let tapCount = 0;
      let tapTimer: any;
      document.querySelectorAll('*').forEach(el => {
        if (el.textContent?.trim() === 'Silvermist') {
          el.addEventListener('click', (e) => {
            e.stopPropagation();
            tapCount++;
            clearTimeout(tapTimer);
            tapTimer = setTimeout(() => { tapCount = 0; }, 500);
            if (tapCount >= 3) {
              tapCount = 0;
              // Fairy dust effect
              document.querySelectorAll('h1, h2').forEach(h => h.classList.add('fairy-glow-active'));
              // Create fairy sparkles
              for (let i = 0; i < 30; i++) {
                const spark = document.createElement('div');
                spark.classList.add('sparkle');
                spark.style.left = Math.random() * 100 + '%';
                spark.style.top = Math.random() * 100 + '%';
                spark.style.position = 'fixed';
                spark.style.zIndex = '9999';
                spark.style.width = '6px';
                spark.style.height = '6px';
                spark.style.background = '#78c8ff';
                spark.style.boxShadow = '0 0 10px #78c8ff';
                document.body.appendChild(spark);
                setTimeout(() => spark.remove(), 3000);
              }
              setTimeout(() => {
                document.querySelectorAll('.fairy-glow-active').forEach(h => h.classList.remove('fairy-glow-active'));
              }, 5000);
            }
          });
        }
      });
    </script>
  </body>
</html>

<style>
  @import '../styles/global.css';
</style>

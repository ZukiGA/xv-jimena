---
// Link generator for personalized invitations
---
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Generar Links — XV Jimena</title>
  <meta name="robots" content="noindex">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #0a2540; color: #fff; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; }
    .card { background: #1a3a5c; border-radius: 16px; padding: 32px; max-width: 500px; width: 100%; }
    h1 { font-size: 24px; margin-bottom: 8px; }
    p { color: #a7d3f3; font-size: 14px; margin-bottom: 24px; }
    label { display: block; font-size: 13px; color: #a7d3f3; margin-bottom: 6px; }
    input { width: 100%; padding: 12px 16px; border-radius: 10px; border: 1px solid #3a5a7c; background: #0a2540; color: #fff; font-size: 16px; outline: none; }
    input:focus { border-color: #0c8ce9; }
    .link-box { margin-top: 16px; padding: 12px 16px; background: #0a2540; border-radius: 10px; border: 1px solid #3a5a7c; word-break: break-all; font-size: 14px; color: #3aacff; min-height: 44px; display: flex; align-items: center; }
    .btn { display: inline-flex; align-items: center; gap: 8px; margin-top: 12px; padding: 10px 20px; background: #0c8ce9; color: #fff; border: none; border-radius: 10px; font-size: 14px; cursor: pointer; }
    .btn:active { background: #0a6abf; }
    .btn.copied { background: #22c55e; }
    .preview { margin-top: 24px; padding-top: 20px; border-top: 1px solid #3a5a7c; }
    .preview-label { font-size: 12px; color: #a7d3f3; margin-bottom: 8px; }
    .preview-text { font-style: italic; color: #8ec5ed; }
    .batch { margin-top: 24px; padding-top: 20px; border-top: 1px solid #3a5a7c; }
    textarea { width: 100%; padding: 12px; border-radius: 10px; border: 1px solid #3a5a7c; background: #0a2540; color: #fff; font-size: 13px; font-family: monospace; resize: vertical; min-height: 100px; }
    .results { margin-top: 12px; font-size: 13px; font-family: monospace; color: #3aacff; white-space: pre-wrap; word-break: break-all; }
  </style>
</head>
<body>
  <div class="card">
    <h1>🔗 Generar Link Personalizado</h1>
    <p>Escribe el nombre del invitado y copia su link único</p>

    <label>Nombre del invitado</label>
    <input type="text" id="name-input" placeholder="Ej: Tía Lupe" autofocus>

    <div class="link-box" id="link-output">Escribe un nombre arriba...</div>

    <button class="btn" id="copy-btn" disabled>
      📋 Copiar link
    </button>

    <div class="preview" id="preview" style="display:none">
      <div class="preview-label">Vista previa del saludo:</div>
      <div class="preview-text">"Querido(a) <span id="preview-name"></span>, estás invitado(a)"</div>
    </div>

    <div class="batch">
      <label>📋 Generación masiva (un nombre por línea)</label>
      <textarea id="batch-input" placeholder="Tía Lupe&#10;Familia González&#10;Abuela Carmen&#10;Primo Diego"></textarea>
      <button class="btn" id="batch-btn">Generar todos</button>
      <div class="results" id="batch-output"></div>
    </div>
  </div>

  <script>
    const BASE = 'https://zukiga.github.io/xv-jimena/';
    const input = document.getElementById('name-input');
    const output = document.getElementById('link-output');
    const copyBtn = document.getElementById('copy-btn');
    const preview = document.getElementById('preview');
    const previewName = document.getElementById('preview-name');

    function makeLink(name) {
      return BASE + '?n=' + encodeURIComponent(name);
    }

    input.addEventListener('input', () => {
      const name = input.value.trim();
      if (name) {
        const link = makeLink(name);
        output.textContent = link;
        copyBtn.disabled = false;
        preview.style.display = 'block';
        previewName.textContent = name;
      } else {
        output.textContent = 'Escribe un nombre arriba...';
        copyBtn.disabled = true;
        preview.style.display = 'none';
      }
    });

    copyBtn.addEventListener('click', async () => {
      const link = output.textContent;
      try {
        await navigator.clipboard.writeText(link);
        copyBtn.textContent = '✅ Copiado!';
        copyBtn.classList.add('copied');
        setTimeout(() => {
          copyBtn.textContent = '📋 Copiar link';
          copyBtn.classList.remove('copied');
        }, 2000);
      } catch {
        // Fallback
        const ta = document.createElement('textarea');
        ta.value = link;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        copyBtn.textContent = '✅ Copiado!';
        setTimeout(() => { copyBtn.textContent = '📋 Copiar link'; }, 2000);
      }
    });

    // Batch generation
    document.getElementById('batch-btn').addEventListener('click', () => {
      const names = document.getElementById('batch-input').value
        .split('\n')
        .map(n => n.trim())
        .filter(Boolean);
      if (!names.length) return;
      const links = names.map(n => `${n}:\n${makeLink(n)}`).join('\n\n');
      document.getElementById('batch-output').textContent = links;
    });
  </script>
</body>
</html>

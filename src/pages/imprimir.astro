---
// Printable invitation — 5x7 inches, light version
---
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Invitación — XV Años de Jimena</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: #f0f0f0;
      font-family: 'Cormorant Garamond', serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 40px 20px;
      min-height: 100vh;
    }

    .controls {
      margin-bottom: 30px;
      display: flex;
      gap: 12px;
      align-items: center;
    }
    .controls input {
      background: white;
      border: 1px solid #ccc;
      border-radius: 8px;
      padding: 10px 16px;
      color: #0a2540;
      font-family: 'Montserrat', sans-serif;
      font-size: 14px;
      width: 250px;
    }
    .controls input::placeholder { color: #aaa; }
    .controls input:focus { outline: none; border-color: #0a2540; }
    .controls button {
      background: #0a2540;
      border: none;
      border-radius: 8px;
      padding: 10px 20px;
      color: white;
      font-family: 'Montserrat', sans-serif;
      font-size: 13px;
      cursor: pointer;
      letter-spacing: 0.1em;
    }
    .controls button:hover { background: #0f3460; }

    /* Card — light elegant */
    .card {
      width: 5in;
      height: 7in;
      background: #ffffff;
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: #0a2540;
      box-shadow: 0 4px 30px rgba(0,0,0,0.1);
    }

    /* Border frame */
    .card::after {
      content: '';
      position: absolute;
      inset: 14px;
      border: 1px solid rgba(10,37,64,0.1);
      pointer-events: none;
    }

    /* Dew drop */
    .dew-print {
      width: 7px;
      height: 10px;
      background: radial-gradient(circle at 30% 30%, rgba(167,211,243,0.9), rgba(10,80,160,0.3) 60%, rgba(10,80,160,0.1));
      border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
      box-shadow: 0 1px 3px rgba(10,80,160,0.15);
      display: inline-block;
    }

    .silvermist-label {
      font-family: 'Montserrat', sans-serif;
      font-size: 8px;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: rgba(10,37,64,0.3);
      margin-bottom: 6px;
    }

    .sep {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 8px;
    }
    .sep-line {
      width: 30px;
      height: 1px;
      background: rgba(10,37,64,0.15);
    }

    .guest-name {
      font-family: 'Montserrat', sans-serif;
      font-size: 10px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(10,37,64,0.4);
      margin-bottom: 40px;
    }

    .main-name {
      font-size: 72px;
      font-weight: 300;
      letter-spacing: 0.02em;
      line-height: 1;
      margin-bottom: 8px;
      color: #0a2540;
    }

    .xv-label {
      font-family: 'Montserrat', sans-serif;
      font-size: 20px;
      font-weight: 300;
      letter-spacing: 0.5em;
      color: rgba(10,37,64,0.5);
      margin-bottom: 50px;
    }

    .date-text {
      font-family: 'Montserrat', sans-serif;
      font-size: 12px;
      letter-spacing: 0.25em;
      color: #0a2540;
      margin-bottom: 6px;
    }

    .venue-text {
      font-family: 'Montserrat', sans-serif;
      font-size: 9px;
      letter-spacing: 0.15em;
      color: rgba(10,37,64,0.35);
      margin-bottom: 4px;
    }

    .detail-label {
      font-family: 'Montserrat', sans-serif;
      font-size: 7px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(10,37,64,0.3);
      margin-bottom: 3px;
    }

    .detail-value {
      font-size: 14px;
      font-weight: 400;
      color: rgba(10,37,64,0.7);
    }

    .details-row {
      display: flex;
      gap: 40px;
      margin-bottom: 35px;
      text-align: center;
    }

    .blue-note {
      font-size: 11px;
      font-style: italic;
      color: rgba(10,80,160,0.4);
      margin-top: 8px;
    }

    .qr-section {
      position: absolute;
      bottom: 25px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
    }

    .qr-placeholder {
      width: 60px;
      height: 60px;
      border: 1px solid rgba(10,37,64,0.1);
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .qr-label {
      font-family: 'Montserrat', sans-serif;
      font-size: 7px;
      letter-spacing: 0.2em;
      color: rgba(10,37,64,0.25);
    }

    @media print {
      body { background: white; padding: 0; margin: 0; }
      .controls { display: none !important; }
      .card { box-shadow: none; }
      @page { size: 5in 7in; margin: 0; }
    }
  </style>
</head>
<body>

  <div class="controls">
    <input type="text" id="name-input" placeholder="Nombre del invitado" />
    <button onclick="updateName()">Actualizar</button>
    <button onclick="window.print()">🖨️ Imprimir</button>
  </div>

  <div class="card">
    <div style="position: absolute; top: 30px; text-align: center;">
      <div class="sep">
        <span class="sep-line"></span>
        <span class="dew-print"></span>
        <span class="sep-line"></span>
      </div>
      <p class="silvermist-label">Silvermist</p>
    </div>

    <p class="guest-name" id="guest-line" style="display: none;">
      <span id="guest-display"></span>, estás invitada(o)
    </p>

    <h1 class="main-name">Jimena</h1>
    <p class="xv-label">XV</p>

    <div class="details-row">
      <div>
        <p class="detail-label">Misa</p>
        <p class="detail-value">2:00 PM</p>
        <p class="venue-text" style="margin-top: 4px;">Iglesia de Santo Tomás</p>
      </div>
      <div>
        <p class="detail-label">Recepción</p>
        <p class="detail-value">4:00 PM</p>
        <p class="venue-text" style="margin-top: 4px;">Salón Jardín El Carmen</p>
      </div>
    </div>

    <p class="date-text">25 · 07 · 2026</p>
    <p class="venue-text">Santo Tomás Hueyotlipan, Puebla</p>

    <p class="blue-note">El azul es mi color ese día 💧</p>

    <div class="qr-section">
      <div class="qr-placeholder">
        <img id="qr-img" width="56" height="56" alt="QR" style="display:block;" />
      </div>
      <p class="qr-label">jimenaxv.com</p>
    </div>
  </div>

  <script>
    function getGuestParam() {
      const params = new URLSearchParams(window.location.search);
      return params.get('n') || '';
    }

    function updateQR(url) {
      const img = document.getElementById('qr-img');
      img.src = 'https://api.qrserver.com/v1/create-qr-code/?size=120x120&color=0a2540&bgcolor=ffffff&data=' + encodeURIComponent(url);
    }

    function updateName(name) {
      const n = name || document.getElementById('name-input').value.trim();
      const line = document.getElementById('guest-line');
      const display = document.getElementById('guest-display');
      if (n) {
        display.textContent = n;
        line.style.display = 'block';
        updateQR('https://jimenaxv.com/?n=' + encodeURIComponent(n));
      } else {
        line.style.display = 'none';
        updateQR('https://jimenaxv.com');
      }
    }

    const initial = getGuestParam();
    if (initial) document.getElementById('name-input').value = initial;
    updateName(initial || '');
  </script>
</body>
</html>

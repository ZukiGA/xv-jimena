---
import Layout from '../layouts/Layout.astro';
import MagicEntrance from '../components/MagicEntrance.astro';
import Hero from '../components/Hero.astro';
import Countdown from '../components/Countdown.astro';
import EventDetails from '../components/EventDetails.astro';
import Timeline from '../components/Timeline.astro';
import Gallery from '../components/Gallery.astro';
import DressCode from '../components/DressCode.astro';
import GiftRegistry from '../components/GiftRegistry.astro';
import RSVP from '../components/RSVP.astro';
import AddToCalendar from '../components/AddToCalendar.astro';
import Location from '../components/Location.astro';
import PhotoDivider from '../components/PhotoDivider.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import WaveTransition from '../components/WaveTransition.astro';
---

<Layout title="XV Años de Jimena — 25 de Julio 2026">
  <MagicEntrance />
  <FloatingCTA />
  <Hero />
  <Countdown />
  <PhotoDivider src="/images/bg/lake.jpg" alt="Lago con montañas" />
  <EventDetails />
  <WaveTransition color="#0f1d2e" />
  <Gallery />
  <WaveTransition color="#0f1d2e" flip />
  <PhotoDivider src="/images/bg/river.jpg" alt="Río" height="h-[35vh]" />
  <DressCode />
  <Location />
  <AddToCalendar />
  <GiftRegistry />
  <RSVP />
  <PhotoDivider src="/images/bg/snow-valley.jpg" alt="Valle nevado" height="h-[40vh]" />
  <Footer />
</Layout>

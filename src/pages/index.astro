---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Countdown from '../components/Countdown.astro';
import EventDetails from '../components/EventDetails.astro';
import AddToCalendar from '../components/AddToCalendar.astro';
import Timeline from '../components/Timeline.astro';
import Gallery from '../components/Gallery.astro';
import DressCode from '../components/DressCode.astro';
import GiftRegistry from '../components/GiftRegistry.astro';
import RSVP from '../components/RSVP.astro';
import Location from '../components/Location.astro';
import Footer from '../components/Footer.astro';
import PhotoDivider from '../components/PhotoDivider.astro';
---

<Layout title="XV Años de Jimena — 25 de Julio 2026">
  <Hero />
  <Countdown />

  <PhotoDivider src="/images/bg/lake.jpg" alt="Lago con montañas" />

  <EventDetails />
  <AddToCalendar />

  <PhotoDivider src="/images/bg/ice-cave.jpg" alt="Cueva de hielo" />

  <Timeline />
  <DressCode />

  <PhotoDivider src="/images/bg/cable-car.jpg" alt="Teleférico" />

  <Location />
  <GiftRegistry />

  <PhotoDivider src="/images/bg/snow-valley.jpg" alt="Valle nevado" />

  <RSVP />

  <PhotoDivider src="/images/bg/river.jpg" alt="Río" height="h-[40vh]" />

  <Footer />
</Layout>
